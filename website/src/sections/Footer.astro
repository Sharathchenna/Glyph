---
import logoG from "../../assets/logo_g.PNG";
import { downloadUrl } from "../lib/site";
---

<footer class="footer">
	<div class="footer-centered">
		<a href="/" class="footer-logo-icon" aria-label="Glyph home">
			<img src={logoG.src} alt="" class="logo-icon" />
		</a>

		<nav class="footer-links" aria-label="Footer navigation">
			<div class="footer-link-row">
				<a href={downloadUrl} target="_blank" rel="noopener">Download</a>
				<a href="/changelog">Changelog</a>
			</div>
			<div class="footer-link-row">
				<a href="https://docs.glyphformac.com" target="_blank" rel="noopener">Docs</a>
				<a href="https://glyph.userjot.com/?cursor=1&order=top&limit=10" target="_blank" rel="noopener">Feedback</a>
				<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
			</div>
			<div class="footer-link-row">
				<a href="/terms">Terms</a>
				<a href="/privacy">Privacy</a>
				<a href="/legal">Legal</a>
			</div>
		</nav>

		<p class="footer-copy">© 2026 Glyph</p>
	</div>
</footer>
