---
import { downloadUrl } from "../lib/site";
---

<section class="hero">
	<h1>Your thoughts deserve a home,<br /><span class="hero-accent">not a server.</span></h1>
	<p class="hero-sub">Write in markdown. Connect ideas with links. Let AI help only when you ask. Everything lives on your machine — always yours.</p>
	<p class="label">LIGHTWEIGHT · FAST · YOURS</p>
	<div class="hero-cta-stack">
		<div class="hero-actions">
			<a href={downloadUrl} class="btn-primary" target="_blank" rel="noopener">
				<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
					<path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516s1.52.087 2.475-1.258.762-2.391.728-2.43m3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422s1.675-2.789 1.698-2.854-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899s1.219.386 1.843.067c.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758q.52-1.185.473-1.282"/>
				</svg>
				Download for Free
			</a>
		</div>
		<p class="hero-trial">Free 7-day trial · No credit card required</p>
		<div class="install-strip" aria-label="Homebrew install command" data-install-strip>
			<div class="install-strip-bar">
				<code class="install-strip-code" data-install-command>brew install --cask SidhuK/glyph/glyph</code>
				<button class="install-strip-copy" type="button" data-copy-install aria-label="Copy Homebrew install command" title="Copy command">
					<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="9" y="9" width="10" height="10" rx="2"></rect>
						<path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
					</svg>
				</button>
			</div>
		</div>
		<p class="hero-pricing">or buy now · <span class="hero-pricing-original">$15</span> <strong>$9.99</strong> with code <code class="hero-pricing-code">EARLYACCESS</code></p>
	</div>
</section>
