---
const faqs = [
	{
		q: "Is there a subscription?",
		a: "Hell No! For a note-taking app? Are you serious? Glyph is a one-time purchase with lifetime access. No recurring fees, no seat limits, no device binding.",
	},
	{
		q: "Do you collect my data?",
		a: "Never. Why would I want your data anyway? It's not like I'm trying to sell you coupons to your favorite shaving cream. Your notes stay on your Mac as plain markdown files. Nothing is uploaded, tracked, or phoned home.",
	},
	{
		q: "Can I try it before buying?",
		a: 'Yes. Glyph comes with a 7-day free trial. No credit card required — just <a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener" style="text-decoration:underline">download the latest version</a> and start writing.',
	},
	{
		q: "I can't afford it at the listed price. What should I do?",
		a: `I offer a 50% discount for students and indie developers. Reach out on <a href="https://x.com/karat_sidhu" target="_blank" rel="noopener" style="text-decoration:underline">Twitter (I refuse to call it X)</a> or email <a href="mailto:karatsidhu@gmail.com" style="text-decoration:underline">karatsidhu@gmail.com</a> — I built this solo and I know what it's like to stretch a budget. We'll work something out.`,
	},
	{
		q: "Is it open source?",
		a: `Fully public on GitHub. I've got nothing to hide. Official builds are licensed, but you're welcome to clone it and build it yourself.`,
	},
	{
		q: "Is a Windows version planned?",
		a: "Eventually, yes. Glyph is built with cross-platform technology, so Windows and Linux are possible. For now, I'm focused on the Mac version.",
	},
];
---

<section class="section" data-reveal id="faq">
	<p class="label">QUESTIONS</p>
	<h2>Common questions</h2>
	<div class="faq-list">
		{faqs.map((f) => (
			<details class="faq-item">
				<summary class="faq-summary">
					<span class="faq-q">{f.q}</span>
					<span class="faq-plus">+</span>
				</summary>
				<p class="faq-a" set:html={f.a} />
			</details>
		))}
	</div>
</section>
