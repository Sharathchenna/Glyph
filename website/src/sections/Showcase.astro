---
import lightShowcaseAsset from "../../assets/light.jpeg";
import darkShowcaseAsset from "../../assets/dark.jpeg";

const showcaseSizes = "(max-width: 1200px) 96vw, 1100px";
const showcaseWidth = lightShowcaseAsset.width;
const showcaseHeight = lightShowcaseAsset.height;
---

<section class="showcase">
	<div class="showcase-wrap">
		<img
			class="showcase-img"
			src={lightShowcaseAsset.src}
			sizes={showcaseSizes}
			width={showcaseWidth}
			height={showcaseHeight}
			alt="Glyph in light mode"
			loading="eager"
			decoding="async"
			fetchpriority="high"
			data-light-src={lightShowcaseAsset.src}
			data-dark-src={darkShowcaseAsset.src}
			data-light-alt="Glyph in light mode"
			data-dark-alt="Glyph in dark mode"
		/>
	</div>
	<div class="mode-toggle-wrap">
		<button
			class="mode-toggle"
			type="button"
			data-mode-toggle
			aria-label="Switch between light and dark preview"
			aria-pressed="false"
		>
			<svg class="mode-icon icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="5"/>
				<line x1="12" y1="1" x2="12" y2="3"/>
				<line x1="12" y1="21" x2="12" y2="23"/>
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
				<line x1="1" y1="12" x2="3" y2="12"/>
				<line x1="21" y1="12" x2="23" y2="12"/>
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
			</svg>
			<svg class="mode-icon icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
			</svg>
		</button>
	</div>
</section>
