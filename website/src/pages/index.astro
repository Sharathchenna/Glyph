		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: 0.1rem 0.35rem;
		border-radius: 3px;
		line-height: 1;
		margin-left: 0.1rem;
		display: none;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}

	.nav a {
		display: flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		font-family: var(--sans);
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		text-transform: none;
		color: rgba(255, 255, 255, 0.7);
		border-radius: 100px;
		white-space: nowrap;
		transition: color 0.15s;
	}

	.nav a:hover {
		color: #fff;
	}

	.header-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.3rem;
		gap: 0.45rem;
		padding: 0.45rem 1.4rem;
		background: #fff;
		color: #111;
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		white-space: nowrap;
		border-radius: 100px;
		border: none;
		cursor: pointer;
		transition:
			transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
			background 0.2s ease;
	}

	.header-cta:hover {
		background: #f0f0f0;
	}

	.header-hamburger {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		background: transparent;
		border: none;
		color: #fff;
		cursor: pointer;
		margin-left: auto;
		border-radius: 50%;
		transition: background 0.15s;
	}

	.header-hamburger:hover {
		background: rgba(255, 255, 255, 0.1);
	}

	.mobile-nav {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 99;
		background: #111;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
	}

	.mobile-nav.is-open {
		display: flex;
		opacity: 1;
		pointer-events: auto;
	}

	.mobile-nav a {
		font-family: var(--sans);
		font-size: 1.5rem;
		font-weight: 500;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.mobile-nav a:hover {
		opacity: 0.7;
	}

	.mobile-nav .header-cta {
		font-size: 1rem;
		min-height: 3rem;
		padding: 0.6rem 2rem;
	}

	.header-cta:focus-visible,
	.btn-primary:focus-visible,
	.btn-outline:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 2px;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		min-height: 3.4rem;
		padding: 0.9rem 2.4rem;
		background: linear-gradient(180deg, #333 0%, #111 100%);
		color: var(--bg);
		font-family: var(--sans);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		border: none;
		border-radius: 0.85rem;
		box-shadow: 0 2px 12px rgba(17, 17, 17, 0.15), 0 1px 3px rgba(17, 17, 17, 0.1);
		cursor: pointer;
		transition:
			background 0.2s ease,
			transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.25s ease;
	}

	.btn-primary:hover {
		background: linear-gradient(180deg, #3a3a3a 0%, #181818 100%);
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgba(17, 17, 17, 0.18);
	}

	.btn-primary:active {
		transform: translateY(0);
	}

	.btn-outline {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.4rem;
		padding: 0.9rem 2rem;
		background: rgba(255, 255, 255, 0.68);
		color: var(--ink);
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		border: 1px solid rgba(17, 17, 17, 0.08);
		border-radius: 100px;
		cursor: pointer;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.btn-outline:hover {
		background: rgba(17, 17, 17, 0.06);
	}

	/* ── Label ── */
	.label {
		font-family: var(--sans);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		color: var(--faint);
		text-align: center;
		margin-bottom: 0;
	}

	/* ── Hero ── */
	.hero {
		text-align: center;
		padding: 3rem 0 4rem;
		max-width: 800px;
		margin-inline: auto;
	}

	h1 {
		font-family: var(--serif);
		font-size: clamp(3.2rem, 8.5vw, 5.4rem);
		font-weight: 400;
		line-height: 1.15;
		font-style: normal;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin-bottom: 2rem;
	}

	.hero-accent {
		color: #bbb;
	}

	.hero-sub {
		font-family: var(--sans);
		font-size: 1rem;
		color: var(--muted);
		line-height: 1.75;
		max-width: 520px;
		margin: 0 auto 0.5rem;
	}

	.hero-cta-stack {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.6rem;
	}

	.hero-actions {
		display: inline-flex;
		align-items: stretch;
		justify-content: center;
		gap: 0.65rem;
	}

	.hero-trial {
		font-family: var(--sans);
		font-size: 0.75rem;
		color: #bbb;
		letter-spacing: 0.02em;
	}

	.hero-pricing {
		font-family: var(--sans);
		font-size: 0.78rem;
		color: var(--muted);
		letter-spacing: 0.01em;
		line-height: 1.55;
		text-wrap: balance;
	}

	.hero-pricing-original {
		text-decoration: line-through;
		color: #bbb;
	}

	.hero-pricing strong {
		font-weight: 600;
		color: var(--ink);
	}

	.hero-pricing-code {
		font-family: var(--sans);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		background: rgba(17, 17, 17, 0.06);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		color: var(--ink);
	}

	.install-strip {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
		max-width: 34rem;
	}

	.install-strip-bar {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
	}

	.install-strip-code {
		display: block;
		font-family: var(--sans);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--muted);
		line-height: 1.45;
		min-width: 0;
		overflow-wrap: anywhere;
		transition:
			transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
			letter-spacing 0.28s ease,
			opacity 0.28s ease;
	}

	.install-strip.is-typing .install-strip-code {
		transform: translateX(4px);
		letter-spacing: 0.05em;
		opacity: 0.88;
	}

	.install-strip-copy {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border: 1px solid rgba(17, 17, 17, 0.1);
		border-radius: 100px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
		justify-self: end;
	}

	.install-strip-copy.is-copied {
		background: rgba(17, 17, 17, 0.06);
		color: var(--ink);
		border-color: rgba(17, 17, 17, 0.2);
	}

	.install-strip-copy.is-failed {
		border-color: rgba(120, 60, 35, 0.24);
		color: #6b4333;
	}

	.install-strip-copy:hover {
		background: rgba(17, 17, 17, 0.05);
		color: var(--ink);
		border-color: rgba(17, 17, 17, 0.2);
	}

	.install-strip-copy:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 2px;
	}

	.install-strip-status {
		margin-top: 0.5rem;
		font-size: 0.68rem;
		color: var(--faint);
		letter-spacing: 0.03em;
		text-align: center;
		transition:
			color 0.2s ease,
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	.install-strip.is-copied .install-strip-status,
	.install-strip.is-typing .install-strip-status {
		color: var(--ink);
		transform: translateY(-1px);
	}

	/* ── Showcase ── */
	.showcase {
		padding: 3.5rem 0;
		width: min(1100px, 96vw);
		margin-left: calc(-1 * (min(1100px, 96vw) - 100%) / 2);
	}

	.showcase-img {
		width: 100%;
		height: auto;
		display: block;
		transition: opacity 0.4s ease;
		mix-blend-mode: multiply;
	}

	.mode-toggle-wrap {
		display: flex;
		justify-content: center;
		margin-top: 0.8rem;
	}

	.mode-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.3rem 0.6rem;
		background: transparent;
		border: 1px solid var(--border);
		cursor: pointer;
		transition: border-color 0.15s;
	}

	.mode-toggle:hover { border-color: var(--faint); }

	.mode-icon {
		display: block;
		color: var(--faint);
		transition: color 0.2s;
	}

	.icon-sun { color: var(--ink); }
	.showcase.is-dark .icon-sun { color: var(--faint); }
	.showcase.is-dark .icon-moon { color: var(--ink); }

	/* ── Sections ── */
	.section {
		padding: 4.5rem 0;
		text-align: center;
	}

	h2 {
		font-family: var(--serif);
		font-size: clamp(1.8rem, 5vw, 2.4rem);
		font-weight: 400;
		font-style: normal;
		letter-spacing: -0.02em;
		line-height: 1.2;
		color: var(--ink);
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 0.85rem;
		color: var(--muted);
		line-height: 1.7;
		max-width: 480px;
		margin: 0 auto 2.5rem;
	}

	/* ── Feature cards (Dot-style) ── */
	.features-section {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 4rem 0;
		width: min(960px, 94vw);
		margin-inline: auto;
		margin-left: calc(-1 * (min(960px, 94vw) - 100%) / 2);
	}

	.feature-card-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.feature-card-row--thirds {
		grid-template-columns: repeat(3, 1fr);
	}

	.feature-card-row--thirds .feature-card-img {
		max-height: 180px;
	}

	.feature-card-row--tasks {
		grid-template-columns: 2fr 1fr;
	}

	.feature-card-row--tasks > .feature-card {
		padding: 1.8rem 2rem 1rem;
	}

	.feature-card {
		--feature-card-bg: #ffffff;
		--feature-card-border: rgba(17, 17, 17, 0.1);
		position: relative;
		isolation: isolate;
		background: var(--feature-card-bg);
		border: 1px solid var(--feature-card-border);
		border-radius: 0.9rem;
		padding: 1.8rem 2rem;
		text-align: left;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 3px rgba(0, 0, 0, 0.03);
		display: flex;
		flex-direction: column;
	}

	.feature-card::before {
		content: none;
	}

	.feature-card--sand {
		--feature-card-bg: rgba(244, 238, 229, 0.92);
		--feature-card-border: rgba(163, 141, 108, 0.14);
	}

	.feature-card--sage {
		--feature-card-bg: rgba(234, 241, 233, 0.92);
		--feature-card-border: rgba(118, 149, 122, 0.14);
	}

	.feature-card--peach {
		--feature-card-bg: rgba(246, 235, 226, 0.92);
		--feature-card-border: rgba(184, 133, 104, 0.15);
	}

	.feature-card--sky {
		--feature-card-bg: rgba(231, 238, 245, 0.92);
		--feature-card-border: rgba(106, 136, 171, 0.15);
	}

	.feature-card--butter {
		--feature-card-bg: rgba(245, 240, 226, 0.92);
		--feature-card-border: rgba(171, 152, 95, 0.15);
	}

	.feature-card--rose {
		--feature-card-bg: rgba(242, 233, 234, 0.92);
		--feature-card-border: rgba(164, 119, 126, 0.14);
	}

	.feature-card--wide {
		width: 100%;
	}

	.feature-card--wide.feature-card--has-img {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		align-items: center;
	}

	.feature-card--stacked {
		display: flex !important;
		flex-direction: column;
	}

	.feature-card-text {
		max-width: 520px;
	}

	.feature-card-img {
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
		overflow: hidden;
	}

	.feature-card-img img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0.45rem 0 0 0;
	}

	.feature-card--stacked .feature-card-img {
		margin-top: 1.5rem;
		flex: 1;
		align-items: flex-end;
	}

	.feature-card--stacked .feature-card-img img {
		border-radius: 0.45rem 0.45rem 0 0;
	}

	.feature-card-img--wiki-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
	}
	.feature-card-img--wiki-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-card-img--ai-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
	}
	.feature-card-img--ai-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-img--xs {
		max-width: 40%;
		margin: 0 auto;
		border-radius: 1rem !important;
	}

	.feature-card-img--tasks-svg {
		align-items: stretch;
		justify-content: stretch;
		border-radius: 0 0.75rem 0.75rem 0;
		overflow: hidden;
	}

	.feature-card-img--tasks-svg svg {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.feature-card-img--search-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
		flex: 0 !important;
	}

	.feature-card-img--search-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-card-img--themes-svg {
		width: 100%;
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
		flex: 0 !important;
	}

	.feature-card-img--themes-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-eyebrow {
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 500;
		color: rgba(70, 63, 56, 0.7);
		margin-bottom: 0.6rem;
	}

	.feature-heading {
		font-family: var(--sans);
		font-size: clamp(1.3rem, 3vw, 1.7rem);
		font-weight: 500;
		line-height: 1.25;
		color: var(--ink);
		margin-bottom: 0.8rem;
	}

	.feature-body {
		font-family: var(--sans);
		font-size: 0.88rem;
		color: var(--muted);
		line-height: 1.7;
	}

	@media (max-width: 640px) {
		.feature-card-row {
			grid-template-columns: 1fr;
		}
		.feature-card--wide.feature-card--has-img {
			grid-template-columns: 1fr;
			padding-right: 2.4rem;
		}
	}

	/* ── Bento grid ── */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.bento-card-content {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.bento-card-privacy .bento-card-content {
		max-width: 60%;
	}

	.bento-visual-wrapper {
		position: absolute;
		bottom: 24px;
		right: 24px;
		width: 160px;
		height: 160px;
		z-index: 2;
		pointer-events: none;
	}

	.bento-visual-wrapper svg {
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.bento-card-format .bento-visual-wrapper,
	.bento-card-perf .bento-visual-wrapper {
		width: 130px;
		height: 130px;
		bottom: -10px;
		right: -10px;
		opacity: 0.85;
	}

	.feature-card-row .bento-card-format .bento-visual-wrapper {
		position: static;
		width: 100%;
		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-perf .bento-visual-wrapper {
		position: static;
		width: 100%;
		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-format .bento-visual-wrapper svg {
		width: 140px;
		height: 140px;
	}

	/* Privacy hover */
	.svg-privacy .lock-shackle {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
		transform-origin: bottom center;
	}
	.svg-privacy .shield-bg {
		transition: fill 0.5s ease;
	}
	.bento-card-privacy:hover .svg-privacy .lock-shackle {
		transform: translateY(6px);
	}
	.bento-card-privacy:hover .svg-privacy .shield-bg {
		fill: #ebdcc0;
	}

	/* Format hover */
	.svg-format .doc-front {
		transition: transform 0.5s ease;
		transform-origin: center;
	}
	.svg-format .doc-back {
		transition: transform 0.5s ease;
	}
	.svg-format .line {
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.svg-format .md-mark {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.3s ease;
		transform-origin: 35px 40px;
	}
	.bento-card-format:hover .svg-format .doc-front {
		transform: translate(-3px, -3px) rotate(-1.5deg);
	}
	.bento-card-format:hover .svg-format .doc-back {
		transform: translate(3px, 3px) rotate(1.5deg);
	}
	.bento-card-format:hover .svg-format .line-1 { transform: translateX(4px); }
	.bento-card-format:hover .svg-format .line-2 { transform: translateX(6px); transition-delay: 0.05s; }
	.bento-card-format:hover .svg-format .line-3 { transform: translateX(2px); transition-delay: 0.1s; }
	.bento-card-format:hover .svg-format .md-mark {
		transform: scale(1.15) rotate(8deg);
		fill: #618A6D;
	}

	/* Perf hover */
	.svg-perf .gauge-fill {
		transition: stroke-dashoffset 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.svg-perf .bolt {
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.4s ease;
		transform-origin: 50px 50px;
	}
	.bento-card-perf:hover .svg-perf .gauge-fill {
		stroke-dashoffset: 30;
	}
	.bento-card-perf:hover .svg-perf .bolt {
		transform: scale(1.2) translateY(-2px);
		fill: #5b8bc0;
	}

	/* Bento hover tag lift */
	.feature-card--compact:hover .feature-tag {
		background: rgba(255, 255, 255, 0.95);
		transform: translateY(-2px);
		box-shadow: 0 4px 8px rgba(0,0,0,0.04);
	}

	.feature-card--compact:hover .feature-list li::before {
		background: #888;
		transform: scale(1.2);
	}

	@media (max-width: 960px) {
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.bento-card-privacy .bento-card-content {
			max-width: 100%;
		}
		.bento-visual-wrapper {
			opacity: 0.3;
		}
		.feature-card--compact:hover .bento-visual-wrapper {
			opacity: 0.6;
		}
	}

	@media (max-width: 640px) {
		.bento-grid {
			display: flex;
			flex-direction: column;
		}
