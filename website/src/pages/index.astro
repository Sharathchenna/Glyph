---
import darkShowcaseAsset from "../../assets/dark.jpeg";
import lightShowcaseAsset from "../../assets/light.jpeg";
import logoG from "../../assets/logo_g.PNG";

import Layout from "../layouts/Layout.astro";
import { downloadUrl } from "../lib/site";

const showcaseSizes = "(max-width: 1200px) 96vw, 1100px";
const showcaseWidth = lightShowcaseAsset.width;
const showcaseHeight = lightShowcaseAsset.height;
const pageTitle = "Glyph: Local-First Markdown Notes App for macOS";
const pageDescription =
	"Learn how Glyph helps you capture ideas with markdown notes, wikilinks, tasks, and local-first AI on macOS. Private by default, fast, and built for deep work.";
const softwareUrl = Astro.site ? new URL("/", Astro.site).toString() : "/";
const softwareJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "Glyph",
		url: softwareUrl,
		description: pageDescription,
		potentialAction: {
			"@type": "SearchAction",
			target: "https://docs.glyphformac.com?q={search_term_string}",
			"query-input": "required name=search_term_string",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "Glyph",
		applicationCategory: "ProductivityApplication",
		operatingSystem: "macOS",
		description: pageDescription,
		url: softwareUrl,
		offers: {
			"@type": "Offer",
			price: "0",
			priceCurrency: "USD",
		},
	},
];

/* Row 1: 2 wide cards — the anchors */
const ftRow1 = [
	{
		icon: "hgi-quill-write-02",
		title: "Markdown-first. Just write",
		desc: "A calm editor with slash commands, live preview, and helpful formatting tools. Every note is a plain .md file you keep and control.",
	},
	{
		icon: "hgi-ai-brain-04",
		title: "AI that works with your notes",
		desc: "Summarize, draft, and ask questions using your notes as context. Works with your ChatGPT account, OpenAI, Anthropic, Openrouter or local models via Ollama.",
	},
];

/* Row 2: 4 medium cards */
const ftRow2 = [
	{
		icon: "hgi-link-03",
		title: "Linked notes that make sense",
		desc: "Connect ideas with [[wikilinks]] and instantly see backlinks. Your notes build a web of context as you think.",
	},
	{
		icon: "hgi-task-01",
		title: "Notes, tasks, and boards",
		desc: "Structured views without a separate app. Tables, kanban boards, and task lists — all built from your notes and properties.",
	},
	{
		icon: "hgi-search-01",
		title: "Search that keeps up",
		desc: "Press ⌘P and find notes by title, tag, folder, or full text in seconds.",
	},
	{
		icon: "hgi-shield-key",
		title: "Private by default",
		desc: "Your notes stay on your Mac. No forced account, no surprise uploads.",
	},
];

/* Row 3: 6 compact cards — icon + title + short line */
const ftRow3 = [
	{
		icon: "hgi-crab",
		title: "Built with Rust",
		desc: "No Electron, no bloat.",
	},
	{
		icon: "hgi-paint-board",
		title: "Themes",
		desc: "Colors, fonts, shortcuts.",
	},
	{
		icon: "hgi-calendar-03",
		title: "Daily notes",
		desc: "Calendar built in.",
	},
	{
		icon: "hgi-grid-table",
		title: "Collections",
		desc: "Tables and boards from tags.",
	},
	{
		icon: "hgi-eye",
		title: "File preview",
		desc: "Images, PDFs, inline.",
	},
	{
		icon: "hgi-git-merge",
		title: "Git sync",
		desc: "Version history built in.",
	},
];

const faqs = [
	{
		q: "Is there a subscription?",
		a: "Hell No! For a note-taking app? Are you serious? Glyph is a one-time purchase with lifetime access. No recurring fees, no seat limits, no device binding.",
	},
	{
		q: "Do you collect my data?",
		a: "Never. Why would I want your data anyway? It's not like I'm trying to sell you coupons to your favorite shaving cream. Your notes stay on your Mac as plain markdown files. Nothing is uploaded, tracked, or phoned home. Ever.",
	},
	{
		q: "Can I try it before buying?",
		a: 'Yes. Glyph comes with a 7-day free trial. No credit card required — just <a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener" style="text-decoration:underline">download the latest version</a> and start writing.',
	},
	{
		q: "I can't afford it at the listed price. What should I do?",
		a: `Please reach out on <a href="https://x.com/karat_sidhu" target="_blank" rel="noopener" style="text-decoration:underline">X</a> or email <a href="mailto:karatsidhu@gmail.com" style="text-decoration:underline">karatsidhu@gmail.com</a>. I built this solo and I know what it's like to stretch a budget. Students, indie devs, anyone who needs a break — just ask. I'll hook you up.`,
	},
	{
		q: "Is it open source?",
		a: `Fully public on GitHub. I've got nothing to hide. Official builds are licensed, but you're welcome to clone it and build it yourself.`,
	},
	{
		q: "Is a Windows version planned?",
		a: "Eventually, yes. Glyph is built with cross-platform technology, so Windows and Linux are absolutely possible. Right now, all my energy goes into making the Mac experience exceptional.",
	},
];

const footerTrimMarks = Array.from({ length: 30 });
---

<Layout
	title={pageTitle}
	description={pageDescription}
	jsonLd={softwareJsonLd}
	preloadImage={lightShowcaseAsset.src}
	preloadImageSizes={showcaseSizes}
>
	<div class="page">

		<!-- ── HEADER ── -->
		<header class="header">
			<a href="/" class="logo">
				<img src={logoG.src} alt="" class="logo-icon" />
				<span>GLYPH</span>
				<span class="logo-version">EARLY ACCESS</span>
			</a>
			<nav class="nav">
				<a href="#features">Features</a>
				<a href="#pricing">Pricing</a>
				<a href="#faq">FAQs</a>
				<a href="https://docs.glyphformac.com" target="_blank" rel="noopener">Docs</a>
				<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
			</nav>
			<a href={downloadUrl} class="header-cta header-cta--desktop" target="_blank" rel="noopener">Download</a>
			<button class="header-hamburger" type="button" aria-label="Toggle menu" data-hamburger>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line class="hamburger-line hamburger-line--top" x1="4" y1="7" x2="20" y2="7"/><line class="hamburger-line hamburger-line--mid" x1="4" y1="12" x2="20" y2="12"/><line class="hamburger-line hamburger-line--bot" x1="4" y1="17" x2="20" y2="17"/></svg>
			</button>
		</header>
		<div class="mobile-nav" data-mobile-nav>
			<a href="#features">Features</a>
			<a href="#pricing">Pricing</a>
			<a href="#faq">FAQs</a>
			<a href="https://docs.glyphformac.com" target="_blank" rel="noopener">Docs</a>
			<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
			<a href={downloadUrl} class="header-cta" target="_blank" rel="noopener">Download</a>
		</div>

		<!-- ── HERO ── -->
		<section class="hero">
			<h1>A quiet place for your<br />thoughts and ideas.<br /><span class="hero-accent">Always yours.</span></h1>
			<p class="hero-sub">Write in markdown. Connect ideas with links. Let AI help when you ask. Everything lives on your machine — plain files, always yours.</p>
			<p class="label">LOCAL-FIRST · MARKDOWN · MACOS</p>
			<div class="hero-cta-stack">
				<div class="hero-actions">
					<a href={downloadUrl} class="btn-primary" target="_blank" rel="noopener">
						<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516s1.52.087 2.475-1.258.762-2.391.728-2.43m3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422s1.675-2.789 1.698-2.854-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899s1.219.386 1.843.067c.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758q.52-1.185.473-1.282"/></svg>
						Download for Free
					</a>
				</div>
				<p class="hero-trial">Free 7-day trial · No credit card required</p>
				<div class="install-strip" aria-label="Homebrew install command" data-install-strip>
					<div class="install-strip-bar">
						<code class="install-strip-code" data-install-command>brew install --cask SidhuK/glyph/glyph</code>
						<button class="install-strip-copy" type="button" data-copy-install aria-label="Copy Homebrew install command" title="Copy command">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="9" y="9" width="10" height="10" rx="2"></rect>
								<path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
							</svg>
						</button>
					</div>
	
				</div>
				<p class="hero-pricing">or buy now · <span class="hero-pricing-original">$15</span> <strong>$9.99</strong> with code <code class="hero-pricing-code">EARLYACCESS</code></p>
			</div>
		</section>

		<!-- ── SHOWCASE ── -->
		<section class="showcase">
				<div class="showcase-wrap">
					<img
						class="showcase-img"
						src={lightShowcaseAsset.src}
						sizes={showcaseSizes}
						width={showcaseWidth}
						height={showcaseHeight}
						alt="Glyph in light mode"
						loading="eager"
						decoding="async"
						fetchpriority="high"
						data-light-src={lightShowcaseAsset.src}
						data-dark-src={darkShowcaseAsset.src}
						data-light-alt="Glyph in light mode"
						data-dark-alt="Glyph in dark mode"
					/>
			</div>
			<div class="mode-toggle-wrap">
				<button
					class="mode-toggle"
					type="button"
					data-mode-toggle
					aria-label="Switch between light and dark preview"
					aria-pressed="false"
				>
					<svg class="mode-icon icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
					<svg class="mode-icon icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				</button>
			</div>
		</section>

		<!-- ── FEATURES ── -->
		<section class="ft-section" id="features" data-reveal>
			<p class="label">FEATURES</p>
			<h2>Everything you need,<br />nothing you don't</h2>
			<p class="section-sub">Built for writers and thinkers who want power without bloat.</p>

			<div class="ft-bento">
				<div class="ft-row ft-row--2">
					{ftRow1.map((f) => (
						<div class="ft-card ft-card--lg">
							<i class={`hgi-stroke ${f.icon} ft-card__icon`} aria-hidden="true"></i>
							<h3 class="ft-card__title">{f.title}</h3>
							<p class="ft-card__desc">{f.desc}</p>
						</div>
					))}
				</div>
				<div class="ft-row ft-row--4">
					{ftRow2.map((f) => (
						<div class="ft-card ft-card--md">
							<i class={`hgi-stroke ${f.icon} ft-card__icon`} aria-hidden="true"></i>
							<h3 class="ft-card__title">{f.title}</h3>
							<p class="ft-card__desc">{f.desc}</p>
						</div>
					))}
				</div>
				<div class="ft-row ft-row--6">
					{ftRow3.map((f) => (
						<div class="ft-card ft-card--sm">
							<i class={`hgi-stroke ${f.icon} ft-card__icon`} aria-hidden="true"></i>
							<h3 class="ft-card__title">{f.title}</h3>
							<p class="ft-card__desc">{f.desc}</p>
						</div>
					))}
				</div>
			</div>

			<p class="ft-coda">Plus frontmatter properties, Mermaid diagrams, image embeds, and <a href="https://docs.glyphformac.com" target="_blank" rel="noopener">plenty more</a>.</p>
		</section>

		<!-- ── DESIGN ── -->
		<section class="section" data-reveal>
			<p class="label">DESIGN</p>
			<h2>Obsessively crafted</h2>
			<p class="section-sub">A native macOS app built by a solo developer who sweats the details. Every pixel, every shortcut, every transition.</p>
		</section>

		<!-- ── CTA ── -->
		<section class="section cta" data-reveal id="pricing">
			<p class="label">YOUR NEXT STEP</p>
			<h2>Start writing with<br />Glyph today</h2>
			<div class="cta-receipt">
				<div class="cta-receipt__perforation cta-receipt__perforation--top" aria-hidden="true"></div>
				<div class="cta-receipt__body">
					<div class="cta-receipt__brand">
						<div class="cta-receipt__brand-lockup">
							<span class="cta-receipt__brand-icon">
								<img src={logoG.src} alt="" loading="lazy" decoding="async" />
							</span>
							<div class="cta-receipt__brand-copy">
								<p class="cta-receipt__brand-name">Glyph</p>
								<p class="cta-receipt__brand-meta">Personal license for macOS</p>
							</div>
						</div>
						<span class="cta-receipt__badge">EARLY ACCESS</span>
					</div>
					<div class="cta-receipt__rows">
						<div class="cta-receipt__row">
							<span>License</span>
							<span>Personal</span>
						</div>
						<div class="cta-receipt__row">
							<span>Payment</span>
							<span>One-time</span>
						</div>
						<div class="cta-receipt__row">
							<span>Subscription</span>
							<span>None</span>
						</div>
						<div class="cta-receipt__row">
							<span>Trial</span>
							<span>7 days free</span>
						</div>
					</div>
					<div class="cta-receipt__pricing">
						<div class="cta-receipt__pricing-copy">
							<p class="cta-receipt__pricing-label">Total today</p>
							<p class="cta-receipt__pricing-save">You save $5</p>
							<p class="cta-receipt__pricing-note">Lifetime access, no recurring fees, no credit card required for the trial.</p>
						</div>
						<div class="cta-receipt__pricing-amount">
							<span class="cta-receipt__special">Early Access Pricing</span>
							<p class="cta-receipt__price-line">
								<span class="cta-receipt__price-old">$15</span>
								<span class="cta-receipt__price-new">$9.99</span>
							</p>
							<p class="cta-receipt__code">Use code <span>EARLYACCESS</span> at checkout</p>
						</div>
					</div>
					<a href={downloadUrl} class="cta-receipt__button" target="_blank" rel="noopener">Get Glyph</a>
					<div class="cta-receipt__footer">
						<p>Free 7-day trial</p>
						<p>No credit card required</p>
						<p>Plain markdown files</p>
					</div>
				</div>
				<div class="cta-receipt__perforation cta-receipt__perforation--bottom" aria-hidden="true"></div>
			</div>
		</section>

		<!-- ── FAQ ── -->
		<section class="section" data-reveal id="faq">
			<p class="label">FREQUENT CONCERNS</p>
			<h2>Everything you need to<br />know before you begin</h2>
			<div class="faq-list">
				{faqs.map((f) => (
					<details class="faq-item">
						<summary class="faq-summary">
							<span class="faq-q">{f.q}</span>
							<span class="faq-plus">+</span>
						</summary>
						<p class="faq-a" set:html={f.a} />
					</details>
				))}
			</div>
		</section>

		<section class="early-access-note" data-reveal>
			<p class="label">EARLY ACCESS</p>
			<h2>Still early. Actively evolving.</h2>
			<p class="section-sub early-access-copy">Glyph is in early access and active development. I am building it as a solo developer project, and your support helps me keep developing it further.</p>
		</section>

		<!-- ── FOOTER ── -->
		<footer class="footer">
			<div class="footer-shell">
				<div class="footer-top">
					<div class="footer-brand">
						<a href="/" class="footer-logo">
							<img src={logoG.src} alt="" class="logo-icon" />
							<span>GLYPH</span>
						</a>
						<p class="footer-tagline">Local-first notes for macOS. Private, calm, and built around your own files.</p>
					</div>
					<nav class="footer-links" aria-label="Footer">
						<a href="https://docs.glyphformac.com" target="_blank" rel="noopener">Docs</a>
						<a href={downloadUrl} target="_blank" rel="noopener">Download</a>
						<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
						<a href="/terms">Terms</a>
						<a href="/privacy">Privacy</a>
						<a href="/legal">Legal</a>
					</nav>
				</div>
				<div class="footer-meta">
					<p class="footer-copy">© 2026 Glyph</p>
					<p class="footer-credit">Made for quiet work and notes you keep forever.</p>
				</div>
				<div class="footer-showpiece">
					<div class="footer-trim" aria-hidden="true">
						{footerTrimMarks.map((_, index) => (
							<span
								class:list={[
									"footer-trim__mark",
									index % 3 === 1 && "is-warm",
									index % 3 === 2 && "is-soft",
								]}
							/>
						))}
					</div>
					<p class="footer-wordmark" aria-hidden="true">Glyph</p>
				</div>
			</div>
		</footer>

	</div>
</Layout>

<style>
	/* ── Page ── */
	.page {
		width: min(720px, 90vw);
		margin-inline: auto;
	}

	/* ── Header ── */
	.header {
		position: sticky;
		top: 1rem;
		z-index: 100;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		width: fit-content;
		margin: 0 auto;
		padding: 0.45rem 0.75rem 0.45rem 1.2rem;
		background: #111;
		backdrop-filter: blur(12px);
		border-radius: 100px;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 2px 8px rgba(0, 0, 0, 0.2);
		border: 1px solid rgba(255, 255, 255, 0.08);
		gap: 0.7rem;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		margin-right: 6rem;
		color: #fff;
	}

	.logo-icon {
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 4px;
	}

	.logo-version {
		font-size: 0.55rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: rgba(255, 255, 255, 0.5);
		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: 0.1rem 0.35rem;
		border-radius: 3px;
		line-height: 1;
		margin-left: 0.1rem;
		display: none;
	}

	.nav {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}

	.nav a {
		display: flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		font-family: var(--sans);
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		text-transform: none;
		color: rgba(255, 255, 255, 0.7);
		border-radius: 100px;
		white-space: nowrap;
		transition: color 0.15s;
	}

	.nav a:hover {
		color: #fff;
	}

	.header-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.3rem;
		gap: 0.45rem;
		padding: 0.45rem 1.4rem;
		background: #fff;
		color: #111;
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		white-space: nowrap;
		border-radius: 100px;
		border: none;
		cursor: pointer;
		transition:
			transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
			background 0.2s ease;
	}

	.header-cta:hover {
		background: #f0f0f0;
	}

	.header-hamburger {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		background: transparent;
		border: none;
		color: #fff;
		cursor: pointer;
		margin-left: auto;
		border-radius: 50%;
		transition: background 0.15s;
	}

	.header-hamburger:hover {
		background: rgba(255, 255, 255, 0.1);
	}

	.mobile-nav {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 99;
		background: #111;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
	}

	.mobile-nav.is-open {
		display: flex;
		opacity: 1;
		pointer-events: auto;
	}

	.mobile-nav a {
		font-family: var(--sans);
		font-size: 1.5rem;
		font-weight: 500;
		color: #fff;
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.mobile-nav a:hover {
		opacity: 0.7;
	}

	.mobile-nav .header-cta {
		font-size: 1rem;
		min-height: 3rem;
		padding: 0.6rem 2rem;
		color: #111;
	}

	.header-cta:focus-visible,
	.btn-primary:focus-visible,
	.btn-outline:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 2px;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		min-height: 3.4rem;
		padding: 0.9rem 2.4rem;
		background: linear-gradient(180deg, #333 0%, #111 100%);
		color: var(--bg);
		font-family: var(--sans);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		border: none;
		border-radius: 0.85rem;
		box-shadow: 0 2px 12px rgba(17, 17, 17, 0.15), 0 1px 3px rgba(17, 17, 17, 0.1);
		cursor: pointer;
		transition:
			background 0.2s ease,
			transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.25s ease;
	}

	.btn-primary:hover {
		background: linear-gradient(180deg, #3a3a3a 0%, #181818 100%);
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgba(17, 17, 17, 0.18);
	}

	.btn-primary:active {
		transform: translateY(0);
	}

	.btn-outline {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.4rem;
		padding: 0.9rem 2rem;
		background: rgba(255, 255, 255, 0.68);
		color: var(--ink);
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		border: 1px solid rgba(17, 17, 17, 0.08);
		border-radius: 100px;
		cursor: pointer;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.btn-outline:hover {
		background: rgba(17, 17, 17, 0.06);
	}

	/* ── Label ── */
	.label {
		font-family: var(--sans);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		color: var(--faint);
		text-align: center;
		margin-bottom: 0;
	}

	/* ── Hero ── */
	.hero {
		text-align: center;
		padding: 3rem 0 4rem;
		max-width: 800px;
		margin-inline: auto;
	}

	h1 {
		font-family: var(--serif);
		font-size: clamp(2.6rem, 7vw, 4.4rem);
		font-weight: 400;
		line-height: 1.15;
		font-style: normal;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin-bottom: 2rem;
	}

	.hero-accent {
		color: #bbb;
	}

	.hero-sub {
		font-family: var(--sans);
		font-size: 1rem;
		color: var(--muted);
		line-height: 1.75;
		max-width: 520px;
		margin: 0 auto 0.5rem;
	}

	.hero-cta-stack {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		gap: 0.35rem;
		margin-top: 1.6rem;
	}

	.hero-actions {
		display: inline-flex;
		align-items: stretch;
		justify-content: center;
		gap: 0.65rem;
	}

	.hero-trial {
		font-family: var(--sans);
		font-size: 0.75rem;
		color: #bbb;
		letter-spacing: 0.02em;
	}

	.hero-pricing {
		font-family: var(--sans);
		font-size: 0.78rem;
		color: var(--muted);
		letter-spacing: 0.01em;
		line-height: 1.55;
		text-wrap: balance;
	}

	.hero-pricing-original {
		text-decoration: line-through;
		color: #bbb;
	}

	.hero-pricing strong {
		font-weight: 600;
		color: var(--ink);
	}

	.hero-pricing-code {
		font-family: var(--sans);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		background: rgba(17, 17, 17, 0.06);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		color: var(--ink);
	}

	.install-strip {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
		max-width: 34rem;
	}

	.install-strip-bar {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
	}

	.install-strip-code {
		display: block;
		font-family: var(--sans);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--muted);
		line-height: 1.45;
		min-width: 0;
		overflow-wrap: anywhere;
		transition:
			transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
			letter-spacing 0.28s ease,
			opacity 0.28s ease;
	}

	.install-strip.is-typing .install-strip-code {
		transform: translateX(4px);
		letter-spacing: 0.05em;
		opacity: 0.88;
	}

	.install-strip-copy {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border: 1px solid rgba(17, 17, 17, 0.1);
		border-radius: 100px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
		justify-self: end;
	}

	.install-strip-copy.is-copied {
		background: rgba(17, 17, 17, 0.06);
		color: var(--ink);
		border-color: rgba(17, 17, 17, 0.2);
	}

	.install-strip-copy.is-failed {
		border-color: rgba(120, 60, 35, 0.24);
		color: #6b4333;
	}

	.install-strip-copy:hover {
		background: rgba(17, 17, 17, 0.05);
		color: var(--ink);
		border-color: rgba(17, 17, 17, 0.2);
	}

	.install-strip-copy:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 2px;
	}

	.install-strip-status {
		margin-top: 0.5rem;
		font-size: 0.68rem;
		color: var(--faint);
		letter-spacing: 0.03em;
		text-align: center;
		transition:
			color 0.2s ease,
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	.install-strip.is-copied .install-strip-status,
	.install-strip.is-typing .install-strip-status {
		color: var(--ink);
		transform: translateY(-1px);
	}

	/* ── Showcase ── */
	.showcase {
		padding: 3.5rem 0;
		width: min(1300px, 98vw);
		margin-left: calc(-1 * (min(1300px, 98vw) - 100%) / 2);
	}

	.showcase-img {
		width: 100%;
		height: auto;
		display: block;
		transition: opacity 0.4s ease;
		mix-blend-mode: multiply;
		border-radius: 1rem;
	}

	.mode-toggle-wrap {
		display: flex;
		justify-content: center;
		margin-top: 0.8rem;
	}

	.mode-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.3rem 0.6rem;
		background: transparent;
		border: 1px solid var(--border);
		cursor: pointer;
		transition: border-color 0.15s;
	}

	.mode-toggle:hover { border-color: var(--faint); }

	.mode-icon {
		display: block;
		color: var(--faint);
		transition: color 0.2s;
	}

	.icon-sun { color: var(--ink); }
	.showcase.is-dark .icon-sun { color: var(--faint); }
	.showcase.is-dark .icon-moon { color: var(--ink); }

	/* ── Sections ── */
	.section {
		padding: 4.5rem 0;
		text-align: center;
	}

	h2 {
		font-family: var(--serif);
		font-size: clamp(1.8rem, 5vw, 2.4rem);
		font-weight: 400;
		font-style: normal;
		letter-spacing: -0.02em;
		line-height: 1.2;
		color: var(--ink);
		margin-bottom: 1rem;
	}

	.section-sub {
		font-size: 0.85rem;
		color: var(--muted);
		line-height: 1.7;
		max-width: 480px;
		margin: 0 auto 2.5rem;
	}

	/* ── Feature cards (Dot-style) ── */
	.features-section {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 4rem 0;
		width: min(960px, 94vw);
		margin-inline: auto;
		margin-left: calc(-1 * (min(960px, 94vw) - 100%) / 2);
	}

	.feature-card-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.feature-card-row--thirds {
		grid-template-columns: repeat(3, 1fr);
	}

	.feature-card-row--thirds .feature-card-img {
		max-height: 180px;
	}

	.feature-card-row--tasks {
		grid-template-columns: 2fr 1fr;
	}

	.feature-card-row--tasks > .feature-card {
		padding: 1.8rem 2rem 1rem;
	}

	.feature-card {
		--feature-card-bg: #ffffff;
		--feature-card-border: rgba(17, 17, 17, 0.1);
		position: relative;
		isolation: isolate;
		background: var(--feature-card-bg);
		border: 1px solid var(--feature-card-border);
		border-radius: 0.9rem;
		padding: 1.8rem 2rem;
		text-align: left;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 3px rgba(0, 0, 0, 0.03);
		display: flex;
		flex-direction: column;
	}

	.feature-card::before {
		content: none;
	}

	.feature-card--sand {
		--feature-card-bg: rgba(244, 238, 229, 0.92);
		--feature-card-border: rgba(163, 141, 108, 0.14);
	}

	.feature-card--sage {
		--feature-card-bg: rgba(234, 241, 233, 0.92);
		--feature-card-border: rgba(118, 149, 122, 0.14);
	}

	.feature-card--peach {
		--feature-card-bg: rgba(246, 235, 226, 0.92);
		--feature-card-border: rgba(184, 133, 104, 0.15);
	}

	.feature-card--sky {
		--feature-card-bg: rgba(231, 238, 245, 0.92);
		--feature-card-border: rgba(106, 136, 171, 0.15);
	}

	.feature-card--butter {
		--feature-card-bg: rgba(245, 240, 226, 0.92);
		--feature-card-border: rgba(171, 152, 95, 0.15);
	}

	.feature-card--rose {
		--feature-card-bg: rgba(242, 233, 234, 0.92);
		--feature-card-border: rgba(164, 119, 126, 0.14);
	}

	.feature-card--wide {
		width: 100%;
	}

	.feature-card--wide.feature-card--has-img {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		align-items: center;
	}

	.feature-card--stacked {
		display: flex !important;
		flex-direction: column;
	}

	.feature-card-text {
		max-width: 520px;
	}

	.feature-card-img {
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
		overflow: hidden;
	}

	.feature-card-img img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0.45rem 0 0 0;
	}

	.feature-card--stacked .feature-card-img {
		margin-top: 1.5rem;
		flex: 1;
		align-items: flex-end;
	}

	.feature-card--stacked .feature-card-img img {
		border-radius: 0.45rem 0.45rem 0 0;
	}

	.feature-card-img--wiki-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
	}
	.feature-card-img--wiki-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-card-img--ai-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
	}
	.feature-card-img--ai-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-img--xs {
		max-width: 40%;
		margin: 0 auto;
		border-radius: 1rem !important;
	}

	.feature-card-img--tasks-svg {
		align-items: stretch;
		justify-content: stretch;
		border-radius: 0 0.75rem 0.75rem 0;
		overflow: hidden;
	}

	.feature-card-img--tasks-svg svg {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.feature-card-img--search-svg {
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
		flex: 0 !important;
	}

	.feature-card-img--search-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-card-img--themes-svg {
		width: 100%;
		align-items: center;
		justify-content: center;
		overflow: visible;
		margin-top: 0.5rem !important;
		flex: 0 !important;
	}

	.feature-card-img--themes-svg svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.feature-eyebrow {
		font-family: var(--sans);
		font-size: 0.78rem;
		font-weight: 500;
		color: rgba(70, 63, 56, 0.7);
		margin-bottom: 0.6rem;
	}

	.feature-heading {
		font-family: var(--sans);
		font-size: clamp(1.3rem, 3vw, 1.7rem);
		font-weight: 500;
		line-height: 1.25;
		color: var(--ink);
		margin-bottom: 0.8rem;
	}

	.feature-body {
		font-family: var(--sans);
		font-size: 0.88rem;
		color: var(--muted);
		line-height: 1.7;
	}

	@media (max-width: 640px) {
		.feature-card-row {
			grid-template-columns: 1fr;
		}
		.feature-card--wide.feature-card--has-img {
			grid-template-columns: 1fr;
			padding-right: 2.4rem;
		}
	}

	/* ── Bento grid ── */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.bento-card-content {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.bento-card-privacy .bento-card-content {
		max-width: 60%;
	}

	.bento-visual-wrapper {
		position: absolute;
		bottom: 24px;
		right: 24px;
		width: 160px;
		height: 160px;
		z-index: 2;
		pointer-events: none;
	}

	.bento-visual-wrapper svg {
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.bento-card-format .bento-visual-wrapper,
	.bento-card-perf .bento-visual-wrapper {
		width: 130px;
		height: 130px;
		bottom: -10px;
		right: -10px;
		opacity: 0.85;
	}

	.feature-card-row .bento-card-format .bento-visual-wrapper {
		position: static;
		width: 100%;
		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-perf .bento-visual-wrapper {
		position: static;
		width: 100%;
		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-format .bento-visual-wrapper svg {
		width: 140px;
		height: 140px;
	}

	/* Privacy hover */
	.svg-privacy .lock-shackle {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
		transform-origin: bottom center;
	}
	.svg-privacy .shield-bg {
		transition: fill 0.5s ease;
	}
	.bento-card-privacy:hover .svg-privacy .lock-shackle {
		transform: translateY(6px);
	}
	.bento-card-privacy:hover .svg-privacy .shield-bg {
		fill: #ebdcc0;
	}

	/* Format hover */
	.svg-format .doc-front {
		transition: transform 0.5s ease;
		transform-origin: center;
	}
	.svg-format .doc-back {
		transition: transform 0.5s ease;
	}
	.svg-format .line {
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.svg-format .md-mark {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.3s ease;
		transform-origin: 35px 40px;
	}
	.bento-card-format:hover .svg-format .doc-front {
		transform: translate(-3px, -3px) rotate(-1.5deg);
	}
	.bento-card-format:hover .svg-format .doc-back {
		transform: translate(3px, 3px) rotate(1.5deg);
	}
	.bento-card-format:hover .svg-format .line-1 { transform: translateX(4px); }
	.bento-card-format:hover .svg-format .line-2 { transform: translateX(6px); transition-delay: 0.05s; }
	.bento-card-format:hover .svg-format .line-3 { transform: translateX(2px); transition-delay: 0.1s; }
	.bento-card-format:hover .svg-format .md-mark {
		transform: scale(1.15) rotate(8deg);
		fill: #618A6D;
	}

	/* Perf hover */
	.svg-perf .gauge-fill {
		transition: stroke-dashoffset 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.svg-perf .bolt {
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.4s ease;
		transform-origin: 50px 50px;
	}
	.bento-card-perf:hover .svg-perf .gauge-fill {
		stroke-dashoffset: 30;
	}
	.bento-card-perf:hover .svg-perf .bolt {
		transform: scale(1.2) translateY(-2px);
		fill: #5b8bc0;
	}

	/* Bento hover tag lift */
	.feature-card--compact:hover .feature-tag {
		background: rgba(255, 255, 255, 0.95);
		transform: translateY(-2px);
		box-shadow: 0 4px 8px rgba(0,0,0,0.04);
	}

	.feature-card--compact:hover .feature-list li::before {
		background: #888;
		transform: scale(1.2);
	}

	@media (max-width: 960px) {
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.bento-card-privacy .bento-card-content {
			max-width: 100%;
		}
		.bento-visual-wrapper {
			opacity: 0.3;
		}
		.feature-card--compact:hover .bento-visual-wrapper {
			opacity: 0.6;
		}
	}

	@media (max-width: 640px) {
		.bento-grid {
			display: flex;
			flex-direction: column;
		}
		.bento-visual-wrapper {
			width: 100px;
			height: 100px;
			bottom: 10px;
			right: 10px;
		}
	}

	/* ── Compact feature cards ── */
	.feature-card--compact {
		padding: 1.8rem 2rem;
	}

	.feature-card--compact .feature-heading {
		margin-bottom: 0.5rem;
	}

	.feature-card--compact .feature-body {
		font-size: 0.82rem;
	}

	.feature-list {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
	}

	.feature-list li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--muted);
	}

	.feature-list li::before {
		content: "";
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 50%;
		background: var(--muted);
		opacity: 0.5;
		flex-shrink: 0;
	}

	.feature-badge-row,
	.feature-tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.feature-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.6rem;
		border-radius: 0.4rem;
		font-size: 0.75rem;
		font-weight: 500;
		background: rgba(241, 245, 249, 0.8);
		color: #475569;
		border: 1px solid rgba(0,0,0,0.04);
		font-family: var(--mono);
	}

	.feature-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.6rem;
		border-radius: 0.4rem;
		font-size: 0.75rem;
		font-weight: 500;
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(0,0,0,0.08);
		color: #334155;
	}


	/* ── Features ── */
	.ft-section {
		padding: 5rem 0 3rem;
		text-align: center;
		width: min(960px, 94vw);
		margin-inline: auto;
		margin-left: calc(-1 * (min(960px, 94vw) - 100%) / 2);
	}

	.ft-bento {
		display: flex;
		flex-direction: column;
		margin-top: 2.5rem;
		border: 1px solid rgba(17, 17, 17, 0.13);
		border-radius: 0.45rem;
		overflow: hidden;
	}

	.ft-row {
		display: grid;
		border-bottom: 1px solid rgba(17, 17, 17, 0.13);
	}

	.ft-row:last-child {
		border-bottom: none;
	}

	.ft-row--2 { grid-template-columns: repeat(2, 1fr); }
	.ft-row--4 { grid-template-columns: repeat(4, 1fr); }
	.ft-row--6 { grid-template-columns: repeat(6, 1fr); }

	.ft-card {
		padding: 1.4rem 1.35rem;
		text-align: left;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		border-right: 1px solid rgba(17, 17, 17, 0.13);
	}

	.ft-card:last-child {
		border-right: none;
	}

	.ft-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: auto;
		height: auto;
		font-size: 1rem;
		line-height: 1;
		color: var(--ink);
		opacity: 0.45;
		margin-bottom: 0.35rem;
		align-self: flex-start;
	}

	.ft-card__title {
		font-family: var(--sans);
		font-weight: 700;
		line-height: 1.3;
		color: var(--ink);
		letter-spacing: -0.02em;
	}

	.ft-card__desc {
		font-family: var(--sans);
		color: var(--muted);
		line-height: 1.6;
	}

	/* ── Large cards (Row 1) ── */
	.ft-card--lg {
		padding: 1.75rem 1.7rem;
		gap: 0.45rem;
	}
	.ft-card--lg .ft-card__icon {
		font-size: 1.15rem;
	}
	.ft-card--lg .ft-card__title { font-size: 1.15rem; }
	.ft-card--lg .ft-card__desc { font-size: 0.84rem; }

	/* ── Medium cards (Row 2) ── */
	.ft-card--md .ft-card__title { font-size: 0.92rem; }
	.ft-card--md .ft-card__desc { font-size: 0.78rem; }

	/* ── Small cards (Row 3) ── */
	.ft-card--sm {
		padding: 1.15rem 1rem;
		gap: 0.25rem;
		align-items: flex-start;
		text-align: left;
	}
	.ft-card--sm .ft-card__icon {
		font-size: 1rem;
		margin-bottom: 0.2rem;
	}
	.ft-card--sm .ft-card__title { font-size: 0.78rem; }
	.ft-card--sm .ft-card__desc {
		font-size: 0.72rem;
		display: block;
	}

	.ft-coda {
		margin-top: 1.75rem;
		font-family: var(--sans);
		font-size: 0.8rem;
		color: var(--faint);
		letter-spacing: 0.01em;
		line-height: 1.6;
	}

	.ft-coda a {
		color: var(--muted);
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-color: rgba(17, 17, 17, 0.15);
		transition: color 0.15s ease, text-decoration-color 0.15s ease;
	}

	.ft-coda a:hover {
		color: var(--ink);
		text-decoration-color: var(--ink);
	}

	@media (max-width: 820px) {
		.ft-row--4 { grid-template-columns: repeat(2, 1fr); }
		.ft-row--6 { grid-template-columns: repeat(3, 1fr); }

		/* Add bottom borders for wrapped cards */
		.ft-row--4 .ft-card:nth-child(1),
		.ft-row--4 .ft-card:nth-child(2) {
			border-bottom: 1px solid rgba(17, 17, 17, 0.13);
		}
		.ft-row--4 .ft-card:nth-child(2) {
			border-right: none;
		}
	}

	@media (max-width: 520px) {
		.ft-section {
			width: 100%;
			margin-left: 0;
		}

		.ft-bento { margin-top: 2rem; }
		.ft-row--2 { grid-template-columns: 1fr; }
		.ft-row--4 { grid-template-columns: repeat(2, 1fr); }
		.ft-row--6 { grid-template-columns: repeat(3, 1fr); }

		.ft-card--lg { padding: 1.4rem 1.3rem; }

		/* Stack large cards — first card needs bottom border */
		.ft-row--2 .ft-card:first-child {
			border-right: none;
			border-bottom: 1px solid rgba(17, 17, 17, 0.13);
		}
	}

	/* ── FAQ ── */
	.faq-list {
		text-align: left;
		margin-top: 2rem;
		border: 1px solid var(--border);
	}

	.faq-item {
		border-bottom: 1px solid var(--border);
	}

	.faq-item:last-child { border-bottom: none; }

	.faq-summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.2rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
		transition: background 0.15s;
	}

	.faq-summary:hover { background: rgba(0,0,0,0.015); }
	.faq-summary::-webkit-details-marker { display: none; }
	.faq-summary::marker { display: none; content: ''; }

	.faq-q {
		font-size: 0.85rem;
		font-weight: 500;
		line-height: 1.55;
	}

	.faq-plus {
		font-size: 1rem;
		color: var(--faint);
		transition: transform 0.2s;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	.faq-item[open] .faq-plus { transform: rotate(45deg); }

	.faq-a {
		padding: 0 1.2rem 1.2rem;
		font-size: 0.82rem;
		color: var(--muted);
		line-height: 1.7;
		overflow-wrap: anywhere;
	}

	/* ── CTA ── */
	.cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 5rem 0;
	}

	.cta .label,
	.cta h2 {
		width: 100%;
	}

	.cta-receipt {
		position: relative;
		align-self: center;
		width: min(31rem, calc(100vw - 2rem));
		max-width: 100%;
		margin: 1.8rem auto 0;
		margin-inline: auto;
		border: 1px solid rgba(213, 203, 188, 0.9);
		border-radius: 0.55rem;
		background: rgba(255, 253, 248, 0.98);
		overflow: hidden;
	}

	.cta-receipt__body {
		padding: 1.55rem 1.3rem 1.25rem;
	}

	.cta-receipt__perforation {
		height: 0.82rem;
		background:
			radial-gradient(circle at 0.42rem 50%, rgba(239, 235, 228, 0.98) 0.22rem, transparent 0.24rem)
			left center / 1.15rem 100% repeat-x;
	}

	.cta-receipt__brand {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding-bottom: 1rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__brand-lockup {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-align: center;
	}

	.cta-receipt__brand-copy {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.cta-receipt__brand-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.45rem;
		background: transparent;
		border: none;
		flex: none;
	}

	.cta-receipt__brand-icon img {
		width: 2.5rem;
		height: 2.5rem;
		display: block;
		border-radius: 0.35rem;
	}

	.cta-receipt__brand-name {
		font-family: var(--serif);
		font-size: 1.2rem;
		line-height: 0.95;
		letter-spacing: -0.03em;
		color: var(--ink);
	}

	.cta-receipt__brand-meta {
		margin-top: 0.24rem;
		font-size: 0.66rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(110, 96, 79, 0.72);
	}

	.cta-receipt__badge {
		display: none;
	}

	.cta-receipt__rows {
		display: grid;
		gap: 0.72rem;
		padding: 1rem 0 0.95rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.79rem;
		line-height: 1.4;
		color: rgba(94, 80, 63, 0.84);
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__row span:last-child {
		font-weight: 500;
		color: rgba(90, 77, 62, 0.76);
	}

	.cta-receipt__pricing {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.85rem;
		align-items: end;
		justify-content: center;
		padding: 1.1rem 0 1rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__pricing-copy {
		text-align: left;
	}

	.cta-receipt__pricing-label {
		font-size: 0.84rem;
		font-weight: 500;
		color: rgba(65, 55, 42, 0.9);
	}

	.cta-receipt__pricing-save {
		margin-top: 0.2rem;
		font-size: 0.7rem;
		color: #159647;
	}

	.cta-receipt__pricing-note {
		margin-top: 0.55rem;
		max-width: 11rem;
		font-size: 0.72rem;
		line-height: 1.55;
		color: rgba(112, 97, 79, 0.66);
	}

	.cta-receipt__pricing-amount {
		text-align: right;
	}

	.cta-receipt__special {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.48rem;
		border-radius: 0.22rem;
		background: var(--accent);
		color: rgba(255, 251, 244, 0.98);
		font-size: 0.58rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transform: rotate(-6deg);
		transform-origin: center;
	}

	.cta-receipt__price-line {
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
		gap: 0.45rem;
		margin-top: 0.42rem;
	}

	.cta-receipt__price-old {
		font-size: 0.95rem;
		line-height: 1;
		color: rgba(130, 117, 101, 0.64);
		text-decoration: line-through;
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__price-new {
		font-family: var(--serif);
		font-size: clamp(2.25rem, 8vw, 3.35rem);
		line-height: 0.88;
		letter-spacing: -0.045em;
		color: var(--ink);
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__code {
		margin-top: 0.38rem;
		font-size: 0.7rem;
		color: rgba(93, 81, 69, 0.72);
	}

	.cta-receipt__code span {
		display: inline-flex;
		align-items: center;
		margin-left: 0.28rem;
		padding: 0.18rem 0.44rem;
		border-radius: 0.35rem;
		background: rgba(17, 17, 17, 0.06);
		border: 1px solid rgba(17, 17, 17, 0.08);
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--ink);
	}

	.cta-receipt__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 3.3rem;
		margin-top: 1.1rem;
		padding: 0.85rem 1.1rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(39, 31, 22, 0.18);
		background: linear-gradient(180deg, #3b342d 0%, #27211c 100%);
		color: rgba(249, 244, 236, 0.98);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		box-shadow: 0 2px 12px rgba(39, 31, 22, 0.2), 0 1px 3px rgba(39, 31, 22, 0.1);
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.cta-receipt__button:hover {
		background: #27211c;
		border-color: rgba(39, 31, 22, 0.26);
		box-shadow: 0 4px 16px rgba(39, 31, 22, 0.25), 0 1px 4px rgba(39, 31, 22, 0.12);
	}

	.cta-receipt__button:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 3px;
	}

	.cta-receipt__footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.4rem 1rem;
		padding-top: 0.95rem;
		margin-top: 0.9rem;
		border-top: 1px dashed rgba(189, 177, 160, 0.5);
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(160, 145, 126, 0.92);
	}

	.early-access-note {
		padding: 0.5rem 0 3.5rem;
		text-align: center;
	}

	.early-access-copy {
		max-width: 34rem;
		margin-inline: auto;
	}

	/* ── Footer ── */
	.footer {
		border-top: none;
		position: relative;
		left: 50%;
		width: 100vw;
		margin-left: -50vw;
		padding: 3rem 0 0;
	}

	.footer-shell {
		background: transparent;
		border: none;
		border-top: 1px solid rgba(149, 129, 102, 0.18);
		border-radius: 0;
		padding: 1.4rem clamp(1.5rem, 4vw, 2.75rem) 0;
		overflow: hidden;
		box-shadow: none;
	}

	.footer-top {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(149, 129, 102, 0.12);
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		max-width: 18rem;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		width: fit-content;
	}

	.footer-tagline {
		font-size: 0.82rem;
		line-height: 1.5;
		color: rgba(96, 80, 60, 0.72);
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.15rem 0.6rem;
	}

	.footer-links a {
		font-size: 0.74rem;
		color: rgba(69, 58, 43, 0.82);
		transition: color 0.15s;
	}

	.footer-links a:hover {
		color: var(--ink);
	}

	.footer-meta {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.85rem;
		padding-top: 0.85rem;
		border-top: 1px solid rgba(149, 129, 102, 0.12);
	}

	.footer-copy {
		font-size: 0.76rem;
		color: rgba(69, 58, 43, 0.82);
		letter-spacing: 0.03em;
		white-space: nowrap;
	}

	.footer-credit {
		font-size: 0.74rem;
		color: rgba(132, 112, 86, 0.72);
		text-align: right;
	}

	.footer-showpiece {
		margin-top: 1rem;
		overflow: hidden;
	}

	.footer-trim {
		display: grid;
		grid-template-columns: repeat(30, minmax(0, 1fr));
		gap: 0.3rem;
		width: min(46rem, 100%);
		margin: 0 auto;
		position: relative;
		z-index: 2;
	}

	.footer-wordmark {
		display: block;
		width: 100%;
		margin-top: -0.06em;
		margin-bottom: -0.42em;
		font-family: var(--serif);
		font-size: clamp(10rem, 34vw, 32rem);
		line-height: 0.7;
		letter-spacing: -0.09em;
		text-align: center;
		color: rgba(132, 112, 86, 0.2);
	}

	.footer-trim__mark {
		display: block;
		height: 0.46rem;
		border-radius: 999px;
		background: #e7dacf;
	}

	.footer-trim__mark.is-warm {
		background: #eed9cf;
	}

	.footer-trim__mark.is-soft {
		background: #dbe3d6;
	}

	/* ── Reveal ── */
	:global(.reveal-pending) {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 0.5s ease, transform 0.5s ease;
	}

	:global([data-reveal].revealed) {
		opacity: 1;
		transform: none;
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.reveal-pending) {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	/* ── Responsive ── */
	@media (max-width: 680px) {
		.nav {
			display: none;
		}

		.header-cta--desktop {
			display: none;
		}

		.header-hamburger {
			display: flex;
		}
	}

	@media (max-width: 900px) {
		.logo {
			width: auto;
			margin-right: 0;
			flex-shrink: 0;
		}

		.privacy-shell__intro {
			padding-inline: 1.35rem;
		}

	}

	@media (max-width: 820px) {
		.feature-card-row,
		.feature-card--wide.feature-card--has-img,
		.privacy-grid {
			grid-template-columns: 1fr;
		}

		.feature-card,
		.feature-card--wide.feature-card--has-img {
			padding: 1.9rem;
		}

		.feature-card--wide.feature-card--has-img {
			padding-right: 1.9rem;
		}

		.feature-card-text {
			max-width: none;
		}

		.feature-card--stacked .feature-card-img,
		.feature-card--wide .feature-card-img {
			margin-top: 1.35rem;
			justify-content: center;
		}

		.privacy-grid > .privacy-cell {
			min-height: auto;
		}

		.privacy-grid {
			padding: 0;
		}

		.privacy-cell {
			padding: 1.35rem 1.25rem 1.3rem;
			border-right: none;
			border-bottom: 1px solid rgba(123, 103, 79, 0.12);
		}

		.privacy-cell:last-child {
			border-bottom: none;
		}

		.privacy-shell__footer {
			flex-direction: column;
			align-items: flex-start;
		}

		.privacy-shell__footer-meta {
			justify-content: flex-start;
		}

		.cta-receipt__brand {
			flex-direction: column;
			align-items: flex-start;
		}

		.footer-top,
		.footer-meta {
			flex-direction: column;
			align-items: flex-start;
		}

		.footer-links {
			justify-content: flex-start;
		}
	}

	@media (max-width: 720px) {
		.install-strip-bar {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			width: 100%;
			align-items: start;
		}

		.hero-pricing {
			max-width: 20rem;
			margin-inline: auto;
		}

		.privacy-preview__row,
		.cta-receipt__row,
		.faq-summary {
			align-items: flex-start;
		}

		.privacy-preview__row {
			flex-wrap: wrap;
		}
	}

	@media (max-width: 640px) {
		.header {
			gap: 0.2rem;
			padding: 0.35rem;
			padding-left: 0.5rem;
		}

		.logo {
			gap: 0.32rem;
			font-size: 0.66rem;
			letter-spacing: 0.1em;
		}

		.logo-icon {
			width: 1.85rem;
			height: 1.85rem;
		}

		.nav {
			width: auto;
			gap: 0;
		}

		.nav a { padding: 0.3rem 0.42rem; font-size: 0.64rem; }
		.header-cta { min-height: 1.9rem; padding: 0.35rem 0.62rem; font-size: 0.64rem; }

		h1 { font-size: clamp(1.8rem, 8vw, 2.4rem); }

		.hero-cta-stack,
		.hero-actions {
			display: flex;
			width: 100%;
		}

		.hero-cta-stack {
			gap: 0.65rem;
		}

		.hero-actions {
			flex-direction: column;
		}

		.install-strip {
			max-width: none;
		}

		.install-strip-code {
			font-size: 0.72rem;
		}

		.privacy-shell {
			border-radius: 1.25rem;
		}

		.privacy-shell__intro {
			padding: 1.2rem 1.15rem 1.1rem;
		}

		.privacy-shell__title {
			font-size: 1.38rem;
		}

		.privacy-grid > .privacy-cell {
			padding: 1.15rem;
		}

		.privacy-shell__footer {
			padding: 0.95rem 1.15rem 1rem;
		}

		.privacy-shell__footer-icon {
			width: 2.55rem;
			height: 2.55rem;
		}

		.cta-receipt {
			border-radius: 1.1rem;
		}

		.cta-receipt__body {
			padding: 1.35rem 1rem 1.1rem;
		}

		.cta-receipt__brand {
			flex-direction: column;
			align-items: flex-start;
		}

		.cta-receipt__brand-lockup,
		.cta-receipt__brand-copy {
			align-items: flex-start;
			text-align: left;
		}

		.cta-receipt__brand-name {
			font-size: 1.7rem;
		}

		.cta-receipt__badge {
			transform: none;
		}

		.cta-receipt__row {
			font-size: 0.87rem;
		}

		.cta-receipt__price-old {
			font-size: 1.2rem;
		}

		.cta-receipt__price-new {
			font-size: 3rem;
		}

		.cta-receipt__footer {
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
			letter-spacing: 0.08em;
		}

		.footer-shell {
			padding: 1.15rem 1rem 0.95rem;
		}

		.footer-links a {
			font-size: 0.72rem;
		}

		.footer-showpiece {
			margin-top: 0.9rem;
			overflow: visible;
		}

		.footer-wordmark {
			font-size: clamp(4.75rem, 24vw, 8rem);
			text-align: left;
			margin-top: 0.45rem;
			margin-bottom: -0.14em;
		}

		.footer-copy,
		.footer-credit {
			white-space: normal;
			text-align: left;
		}

		.footer-trim {
			grid-template-columns: repeat(15, minmax(0, 1fr));
			row-gap: 0.38rem;
			width: 100%;
		}
	}
</style>

<script>
	// Hamburger menu
	const hamburger = document.querySelector('[data-hamburger]');
	const mobileNav = document.querySelector('[data-mobile-nav]');

	hamburger?.addEventListener('click', () => {
		const isOpen = mobileNav?.classList.toggle('is-open');
		hamburger.setAttribute('aria-expanded', String(isOpen));
	});

	mobileNav?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			mobileNav.classList.remove('is-open');
			hamburger?.setAttribute('aria-expanded', 'false');
		});
	});

	const defaultCopyLabel = 'Copy command';
	const copiedCopyLabel = 'Copied';
	const failedCopyLabel = 'Copy failed';

	const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (prefersReducedMotion || !('IntersectionObserver' in window)) {
		revealItems.forEach((el) => el.classList.add('revealed'));
	} else {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.remove('reveal-pending');
						entry.target.classList.add('revealed');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1 }
		);

		revealItems.forEach((el) => {
			const rect = el.getBoundingClientRect();
			if (rect.top <= window.innerHeight * 0.92) {
				el.classList.add('revealed');
				return;
			}

			el.classList.add('reveal-pending');
			observer.observe(el);
		});
	}

	const toggle = document.querySelector('[data-mode-toggle]');
	const showcase = toggle?.closest('.showcase');
	const showcaseImage = showcase?.querySelector('.showcase-img');
	let isDarkMode = false;

	const setShowcaseMode = (darkMode) => {
		if (!(showcaseImage instanceof HTMLImageElement)) return;

		const nextSrc = darkMode ? showcaseImage.dataset.darkSrc : showcaseImage.dataset.lightSrc;
		const nextAlt = darkMode ? showcaseImage.dataset.darkAlt : showcaseImage.dataset.lightAlt;

		if (nextSrc) showcaseImage.src = nextSrc;
		showcaseImage.removeAttribute('srcset');
		if (nextAlt) showcaseImage.alt = nextAlt;

		showcase?.classList.toggle('is-dark', darkMode);
		toggle?.setAttribute('aria-pressed', String(darkMode));
	};

	toggle?.addEventListener('click', () => {
		isDarkMode = !isDarkMode;
		setShowcaseMode(isDarkMode);
	});

	const copyButton = document.querySelector('[data-copy-install]');
	const installStrip = document.querySelector('[data-install-strip]');
	const installStatus = document.querySelector('[data-install-status]');
	const installCommand = document.querySelector('[data-install-command]')?.textContent?.trim();
	let copyResetTimer;

	copyButton?.addEventListener('click', async () => {
		if (!installCommand || !(installStrip instanceof HTMLElement)) return;

		installStrip.classList.remove('is-copied');
		installStrip.classList.remove('is-failed');
		copyButton.classList.remove('is-copied');
		copyButton.classList.remove('is-failed');
		installStrip.classList.add('is-typing');
		if (installStatus instanceof HTMLElement) {
			installStatus.textContent = 'Typing the command into memory...';
		}
		window.clearTimeout(copyResetTimer);

		try {
			await navigator.clipboard.writeText(installCommand);
			window.setTimeout(() => {
				installStrip.classList.remove('is-typing');
				installStrip.classList.add('is-copied');
				copyButton.classList.add('is-copied');
				copyButton.classList.remove('is-failed');
				copyButton.setAttribute('aria-label', copiedCopyLabel);
				copyButton.setAttribute('title', copiedCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Copied. Paste into Terminal.';
				}
			}, 180);
			copyResetTimer = window.setTimeout(() => {
				installStrip.classList.remove('is-typing');
				installStrip.classList.remove('is-copied');
				copyButton.classList.remove('is-copied');
				copyButton.setAttribute('aria-label', defaultCopyLabel);
				copyButton.setAttribute('title', defaultCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Ready for Terminal.';
				}
			}, 1900);
		} catch {
			installStrip.classList.remove('is-typing');
			installStrip.classList.add('is-failed');
			copyButton.classList.add('is-failed');
			copyButton.setAttribute('aria-label', failedCopyLabel);
			copyButton.setAttribute('title', failedCopyLabel);
			if (installStatus instanceof HTMLElement) {
				installStatus.textContent = 'Clipboard access blocked. You can still copy it manually.';
			}
			copyResetTimer = window.setTimeout(() => {
				installStrip.classList.remove('is-failed');
				copyButton.classList.remove('is-failed');
				copyButton.setAttribute('aria-label', defaultCopyLabel);
				copyButton.setAttribute('title', defaultCopyLabel);
				if (installStatus instanceof HTMLElement) {
					installStatus.textContent = 'Ready for Terminal.';
				}
			}, 2200);
		}
	});
</script>
