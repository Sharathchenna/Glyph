		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-perf .bento-visual-wrapper {
		position: static;
		width: 100%;
		height: auto;
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 1;
		margin-top: auto;
		padding-top: 1rem;
	}

	.feature-card-row .bento-card-format .bento-visual-wrapper svg {
		width: 140px;
		height: 140px;
	}

	/* Privacy hover */
	.svg-privacy .lock-shackle {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
		transform-origin: bottom center;
	}
	.svg-privacy .shield-bg {
		transition: fill 0.5s ease;
	}
	.bento-card-privacy:hover .svg-privacy .lock-shackle {
		transform: translateY(6px);
	}
	.bento-card-privacy:hover .svg-privacy .shield-bg {
		fill: #ebdcc0;
	}

	/* Format hover */
	.svg-format .doc-front {
		transition: transform 0.5s ease;
		transform-origin: center;
	}
	.svg-format .doc-back {
		transition: transform 0.5s ease;
	}
	.svg-format .line {
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}
	.svg-format .md-mark {
		transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.3s ease;
		transform-origin: 35px 40px;
	}
	.bento-card-format:hover .svg-format .doc-front {
		transform: translate(-3px, -3px) rotate(-1.5deg);
	}
	.bento-card-format:hover .svg-format .doc-back {
		transform: translate(3px, 3px) rotate(1.5deg);
	}
	.bento-card-format:hover .svg-format .line-1 { transform: translateX(4px); }
	.bento-card-format:hover .svg-format .line-2 { transform: translateX(6px); transition-delay: 0.05s; }
	.bento-card-format:hover .svg-format .line-3 { transform: translateX(2px); transition-delay: 0.1s; }
	.bento-card-format:hover .svg-format .md-mark {
		transform: scale(1.15) rotate(8deg);
		fill: #618A6D;
	}

	/* Perf hover */
	.svg-perf .gauge-fill {
		transition: stroke-dashoffset 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.svg-perf .bolt {
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), fill 0.4s ease;
		transform-origin: 50px 50px;
	}
	.bento-card-perf:hover .svg-perf .gauge-fill {
		stroke-dashoffset: 30;
	}
	.bento-card-perf:hover .svg-perf .bolt {
		transform: scale(1.2) translateY(-2px);
		fill: #5b8bc0;
	}

	/* Bento hover tag lift */
	.feature-card--compact:hover .feature-tag {
		background: rgba(255, 255, 255, 0.95);
		transform: translateY(-2px);
		box-shadow: 0 4px 8px rgba(0,0,0,0.04);
	}

	.feature-card--compact:hover .feature-list li::before {
		background: #888;
		transform: scale(1.2);
	}

	@media (max-width: 960px) {
		.bento-grid {
			grid-template-columns: 1fr;
		}
		.bento-card-privacy .bento-card-content {
			max-width: 100%;
		}
		.bento-visual-wrapper {
			opacity: 0.3;
		}
		.feature-card--compact:hover .bento-visual-wrapper {
			opacity: 0.6;
		}
	}

	@media (max-width: 640px) {
		.bento-grid {
			display: flex;
			flex-direction: column;
		}
		.bento-visual-wrapper {
			width: 100px;
			height: 100px;
			bottom: 10px;
			right: 10px;
		}
	}

	/* ── Compact feature cards ── */
	.feature-card--compact {
		padding: 1.8rem 2rem;
	}

	.feature-card--compact .feature-heading {
		margin-bottom: 0.5rem;
	}

	.feature-card--compact .feature-body {
		font-size: 0.82rem;
	}

	.feature-list {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
	}

	.feature-list li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		font-weight: 500;
		color: var(--muted);
	}

	.feature-list li::before {
		content: "";
		width: 0.3rem;
		height: 0.3rem;
		border-radius: 50%;
		background: var(--muted);
		opacity: 0.5;
		flex-shrink: 0;
	}

	.feature-badge-row,
	.feature-tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.feature-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.6rem;
		border-radius: 0.4rem;
		font-size: 0.75rem;
		font-weight: 500;
		background: rgba(241, 245, 249, 0.8);
		color: #475569;
		border: 1px solid rgba(0,0,0,0.04);
		font-family: var(--mono);
	}

	.feature-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.6rem;
		border-radius: 0.4rem;
		font-size: 0.75rem;
		font-weight: 500;
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid rgba(0,0,0,0.08);
		color: #334155;
	}


	/* ── Features ── */
	.ft-section {
		padding: 5rem 0 3rem;
		text-align: center;
		width: min(1100px, 94vw);
		margin-inline: auto;
		margin-left: calc(-1 * (min(1100px, 94vw) - 100%) / 2);
	}

	.feature-showcase {
		margin-top: 2.5rem;
	}

	.feature-showcase__grid {
		display: flex;
		flex-direction: column;
		gap: 1px;
		border: 1px solid rgba(86, 69, 48, 0.16);
		border-radius: 1.1rem;
		background: rgba(86, 69, 48, 0.14);
		overflow: hidden;
		box-shadow: 0 10px 18px rgba(40, 28, 17, 0.03);
	}

	.feature-showcase__row {
		display: grid;
		gap: 1px;
	}

	.feature-showcase__row--duo {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.feature-showcase__row--quad {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.feature-showcase__row--compact {
		grid-template-columns: repeat(5, minmax(0, 1fr));
	}

	.feature-showcase__card {
		--feature-card-bg: rgba(248, 244, 238, 0.96);
		position: relative;
		background: var(--feature-card-bg);
		padding: 1.65rem 1.55rem;
		text-align: left;
		display: flex;
		flex-direction: column;
		min-height: 13.5rem;
		transition: background 0.35s ease;
	}

	.feature-showcase__card--hero {
		min-height: 16.25rem;
		padding: 1.85rem 1.8rem;
	}

	.feature-showcase__card--compact {
		min-height: 11rem;
	}

	.feature-showcase__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.15rem;
		height: 2.15rem;
		border-radius: 0.75rem;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(86, 69, 48, 0.08);
		font-size: 1rem;
		line-height: 1;
		color: var(--ink);
		opacity: 0.72;
		margin-bottom: 1rem;
		align-self: flex-start;
		transition:
			transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275),
			color 0.25s ease,
			background 0.25s ease;
	}

	.feature-showcase__card:hover .feature-showcase__icon {
		transform: scale(1.08);
		background: rgba(255, 255, 255, 0.92);
	}

	.feature-showcase__card h3 {
		font-family: var(--sans);
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.25;
		color: var(--ink);
		letter-spacing: -0.02em;
		margin-bottom: 0.45rem;
	}

	.feature-showcase__card--hero h3 {
		font-size: 1.12rem;
	}

	.feature-showcase__card p {
		font-family: var(--sans);
		font-size: 0.84rem;
		color: var(--muted);
		line-height: 1.62;
		max-width: 95%;
	}

	.feature-showcase__card--compact p {
		font-size: 0.77rem;
	}

	.feature-showcase__flare {
		margin-top: auto;
		padding-top: 1.75rem;
		display: flex;
		align-items: flex-end;
		min-height: 4.5rem;
		overflow: visible;
	}

	.feature-md-stack {
		position: relative;
		width: 11rem;
		height: 2.75rem;
	}

	.feature-md-chip {
		position: absolute;
		top: 0;
		left: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.42rem 0.7rem;
		border-radius: 0.7rem;
		background: rgba(255, 255, 255, 0.94);
		border: 1px solid rgba(86, 69, 48, 0.12);
		box-shadow: 0 8px 18px rgba(40, 28, 17, 0.05);
		font-size: 0.77rem;
		font-weight: 500;
		color: var(--ink);
		white-space: nowrap;
		transform-origin: bottom left;
		transition:
			transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.4s ease,
			border-color 0.3s ease,
			color 0.3s ease,
			opacity 0.3s ease;
	}

	.feature-md-chip i {
		font-size: 0.85rem;
	}

	.feature-md-chip--one {
		transform: translate(0.7rem, 0.65rem) scale(0.92);
		opacity: 0.5;
		z-index: 1;
	}

	.feature-md-chip--two {
		transform: translate(0.35rem, 0.3rem) scale(0.96);
		opacity: 0.78;
		z-index: 2;
	}

	.feature-md-chip--three {
		transform: translate(0, 0) scale(1);
		z-index: 3;
	}

	.feature-showcase__card:hover .feature-md-chip--one {
		transform: translate(8.4rem, -1.35rem) rotate(12deg);
		opacity: 1;
		color: #8a4fd1;
		border-color: rgba(138, 79, 209, 0.26);
		box-shadow: 0 12px 22px rgba(138, 79, 209, 0.12);
	}

	.feature-showcase__card:hover .feature-md-chip--two {
		transform: translate(4.6rem, -0.45rem) rotate(6deg);
		opacity: 1;
		color: #4e8562;
		border-color: rgba(78, 133, 98, 0.26);
		box-shadow: 0 12px 22px rgba(78, 133, 98, 0.12);
	}

	.feature-showcase__card:hover .feature-md-chip--three {
		transform: translate(-0.9rem, 0.5rem) rotate(-4deg);
		color: #295d88;
		border-color: rgba(41, 93, 136, 0.26);
		box-shadow: 0 12px 22px rgba(41, 93, 136, 0.12);
	}

	.feature-ai-pill,
	.feature-private-pill,
	.feature-link-pill,
	.feature-calendar-pill,
	.feature-git-pill {
		display: inline-flex;
		align-items: center;
	}

	.feature-ai-stack {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
		flex-wrap: nowrap;
	}

	.feature-ai-providers {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.35rem;
		margin-left: auto;
		flex-shrink: 0;
	}

	.feature-ai-provider {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2rem;
		min-width: 2rem;
		padding: 0.38rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(86, 69, 48, 0.08);
		background: rgba(255, 255, 255, 0.88);
		box-shadow: 0 5px 12px rgba(40, 28, 17, 0.04);
		transition:
			transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			box-shadow 0.35s ease,
			border-color 0.25s ease,
			background 0.25s ease;
	}

	.feature-ai-provider img {
		display: block;
		width: auto;
		height: 0.9rem;
		max-width: 1.06rem;
		object-fit: contain;
		transition: transform 0.35s ease;
	}

	.feature-ai-provider--openai img {
		height: 0.92rem;
		max-width: 0.92rem;
	}

	.feature-ai-provider--claude img {
		height: 0.94rem;
		max-width: 0.94rem;
	}

	.feature-ai-provider--gemini img {
		height: 0.92rem;
		max-width: 0.92rem;
	}

	.feature-ai-provider--openrouter {
		min-width: 2.3rem;
	}

	.feature-ai-provider--openrouter img {
		height: 0.64rem;
		max-width: 1.4rem;
	}

	.feature-ai-provider--ollama img {
		height: 0.84rem;
		max-width: 0.98rem;
	}

	.feature-ai-pill {
		position: relative;
		gap: 0.45rem;
		overflow: hidden;
		padding: 0.42rem 0.78rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(164, 130, 222, 0.25);
		background: rgba(250, 245, 255, 0.92);
		color: #6d39b3;
		font-size: 0.78rem;
		font-weight: 500;
		white-space: nowrap;
		transition:
			transform 0.35s ease,
			box-shadow 0.35s ease,
			border-color 0.35s ease;
	}

	.feature-ai-pill i {
		font-size: 0.9rem;
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.feature-ai-pill::before {
		content: "";
		position: absolute;
		inset: 0 auto 0 -100%;
		width: 50%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.9), transparent);
		transform: skewX(-18deg);
		transition: left 0.8s ease;
	}

	.feature-showcase__card:hover .feature-ai-pill {
		transform: translateY(-2px);
		border-color: rgba(164, 130, 222, 0.38);
		box-shadow: 0 10px 18px rgba(138, 79, 209, 0.12);
	}

	.feature-showcase__card:hover .feature-ai-pill i {
		transform: rotate(12deg) scale(1.08);
	}

	.feature-showcase__card:hover .feature-ai-pill::before {
		left: 180%;
	}

	.feature-showcase__card:hover .feature-ai-provider {
		background: rgba(255, 255, 255, 0.96);
		box-shadow: 0 10px 18px rgba(40, 28, 17, 0.08);
	}

	.feature-showcase__card:hover .feature-ai-provider img {
		transform: scale(1.04);
	}

	.feature-showcase__card:hover .feature-ai-provider--openai {
		transform: translateY(-0.18rem) rotate(-5deg);
	}

	.feature-showcase__card:hover .feature-ai-provider--claude {
		transform: translateY(-0.32rem) scale(1.03);
		border-color: rgba(217, 119, 87, 0.18);
	}

	.feature-showcase__card:hover .feature-ai-provider--gemini {
		transform: translateY(-0.26rem) rotate(-3deg);
		border-color: rgba(99, 116, 255, 0.16);
	}

	.feature-showcase__card:hover .feature-ai-provider--openrouter {
		transform: translateY(-0.22rem) rotate(3deg);
		border-color: rgba(17, 17, 17, 0.12);
	}

	.feature-showcase__card:hover .feature-ai-provider--ollama {
		transform: translateY(-0.12rem) rotate(5deg);
	}

	.feature-link-pill {
		gap: 0.15rem;
		padding: 0.4rem 0.72rem;
		border-radius: 0.62rem;
		background: rgba(241, 231, 248, 0.9);
		color: #7b4eb0;
		font-family: var(--font-geist-mono);
		font-size: 0.78rem;
		font-weight: 600;
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}

	.feature-link-pill__bracket {
		opacity: 0.65;
		transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
	}

	.feature-showcase__card:hover .feature-link-pill {
		background: rgba(233, 215, 246, 0.96);
		box-shadow: 0 10px 18px rgba(138, 79, 209, 0.1);
	}

	.feature-showcase__card:hover .feature-link-pill__bracket {
		opacity: 1;
	}

	.feature-showcase__card:hover .feature-link-pill__bracket:first-child {
		transform: translateX(-0.2rem);
	}

	.feature-showcase__card:hover .feature-link-pill__bracket:last-child {
		transform: translateX(0.2rem);
	}

	.feature-kanban {
		display: flex;
		gap: 0.55rem;
	}

	.feature-kanban__col {
		display: flex;
		flex-direction: column;
		gap: 0.28rem;
		width: 2rem;
		height: 2.55rem;
		padding: 0.4rem;
		border-radius: 0.55rem;
		background: rgba(86, 69, 48, 0.08);
	}

	.feature-kanban__item {
		display: block;
		height: 0.42rem;
		border-radius: 999px;
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
	}

	.feature-kanban__item--rose { background: #ce8f87; }
	.feature-kanban__item--blue { background: #6d8ba6; }
	.feature-kanban__item--green { background: #7c9a82; }
	.feature-kanban__item--gold { background: #b89354; }

	.feature-showcase__card:hover .feature-kanban__col:nth-child(1) .feature-kanban__item:nth-child(1) {
		transform: translateY(-0.2rem) rotate(-3deg);
		box-shadow: 0 6px 12px rgba(33, 24, 16, 0.12);
	}

	.feature-showcase__card:hover .feature-kanban__col:nth-child(1) .feature-kanban__item:nth-child(2) {
		transform: translateY(-0.05rem);
	}

	.feature-showcase__card:hover .feature-kanban__col:nth-child(2) .feature-kanban__item {
		transform: translateY(-0.25rem) rotate(2deg);
		box-shadow: 0 6px 12px rgba(33, 24, 16, 0.12);
	}

	.feature-showcase__card:hover .feature-kanban__col:nth-child(3) .feature-kanban__item {
		transform: translateY(-0.12rem);
	}

	.feature-keys {
		display: flex;
		gap: 0.4rem;
	}

	.feature-keys__key {
		min-width: 2rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.38rem 0.58rem;
		border-radius: 0.55rem;
		background: rgba(255, 255, 255, 0.95);
		border: 1px solid rgba(86, 69, 48, 0.14);
		border-bottom-width: 3px;
		font-size: 0.86rem;
		font-weight: 600;
		color: var(--ink);
		transition:
			transform 0.12s ease,
			border-bottom-width 0.12s ease,
			color 0.15s ease;
	}

	.feature-showcase__card:hover .feature-keys__key {
		transform: translateY(2px);
		border-bottom-width: 1px;
		color: #295d88;
	}

	.feature-showcase__card:hover .feature-keys__key:nth-child(2) {
		transition-delay: 0.05s;
	}

	.feature-private-pill {
		gap: 0.45rem;
		padding: 0.42rem 0.8rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(102, 145, 103, 0.22);
		background: rgba(233, 243, 232, 0.96);
		color: #406e4d;
		font-size: 0.78rem;
		font-weight: 500;
		white-space: nowrap;
		transition:
			padding 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			background 0.3s ease,
			box-shadow 0.35s ease;
	}

	.feature-private-pill i {
		font-size: 0.9rem;
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.feature-showcase__card:hover .feature-private-pill {
		padding-inline: 1rem 1.15rem;
		background: rgba(214, 232, 212, 0.98);
		box-shadow: 0 10px 18px rgba(64, 110, 77, 0.1);
	}

	.feature-showcase__card:hover .feature-private-pill i {
		transform: scale(1.12);
	}

	.feature-dots {
		display: flex;
		align-items: center;
	}

	.feature-dots__dot {
		width: 1.05rem;
		height: 1.05rem;
		margin-left: -0.45rem;
		border-radius: 50%;
		border: 2px solid rgba(248, 244, 238, 1);
		box-shadow: 0 4px 10px rgba(40, 28, 17, 0.08);
		transition: margin 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.35s ease;
	}

	.feature-dots__dot:first-child {
		margin-left: 0;
	}

	.feature-dots__dot--terracotta { background: #b57360; }
	.feature-dots__dot--ink { background: #5b8bc0; }
	.feature-dots__dot--sage { background: #7c9a82; }

	.feature-showcase__card:hover .feature-dots__dot {
		margin-left: 0.2rem;
		transform: scale(1.08);
	}

	.feature-calendar-pill {
		padding: 0.28rem 0.75rem;
		border-radius: 0.7rem;
		border: 1px solid rgba(196, 120, 107, 0.25);
		color: #b14b3d;
		font-size: 0.78rem;
		font-weight: 600;
		transition:
			transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			background 0.3s ease,
			color 0.3s ease,
			box-shadow 0.3s ease;
	}

	.feature-showcase__card:hover .feature-calendar-pill {
		background: #b14b3d;
		color: #fffaf6;
		transform: perspective(25rem) rotateX(15deg) translateY(-2px) scale(1.04);
		box-shadow: 0 10px 18px rgba(177, 75, 61, 0.16);
	}

	.feature-tags {
		display: flex;
		align-items: center;
	}

	.feature-tags__tag {
		display: inline-flex;
		align-items: center;
		padding: 0.18rem 0.58rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 600;
		transition:
			transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			margin 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			box-shadow 0.3s ease;
	}

	.feature-tags__tag--blue {
		background: rgba(225, 236, 247, 0.94);
		color: #295d88;
		transform: rotate(-3deg);
		z-index: 2;
	}

	.feature-tags__tag--gold {
		background: rgba(244, 232, 214, 0.96);
		color: #8a6128;
		margin-left: -0.7rem;
		transform: rotate(4deg);
		z-index: 1;
	}

	.feature-showcase__card:hover .feature-tags__tag--blue {
		transform: rotate(0deg) translateY(-2px);
		box-shadow: 0 8px 16px rgba(33, 24, 16, 0.08);
	}

	.feature-showcase__card:hover .feature-tags__tag--gold {
		margin-left: 0.3rem;
		transform: rotate(0deg) translateY(2px);
		box-shadow: 0 8px 16px rgba(33, 24, 16, 0.08);
	}

	.feature-files {
		display: flex;
		align-items: center;
	}

	.feature-files__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		font-size: 1.05rem;
		border-radius: 0.6rem;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(86, 69, 48, 0.08);
		box-shadow: 0 6px 12px rgba(33, 24, 16, 0.05);
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
	}

	.feature-files__icon--front {
		color: #5b8bc0;
		margin-right: -0.55rem;
		z-index: 2;
	}

	.feature-files__icon--back {
		color: #b14b3d;
		z-index: 1;
		opacity: 0.82;
	}

	.feature-showcase__card:hover .feature-files__icon--front {
		transform: translate(-0.22rem, -0.22rem) scale(1.04);
		box-shadow: -4px 10px 18px rgba(91, 139, 192, 0.16);
	}

	.feature-showcase__card:hover .feature-files__icon--back {
		transform: translate(0.22rem, 0.22rem) scale(1.04);
		box-shadow: 4px 10px 18px rgba(177, 75, 61, 0.14);
		opacity: 1;
	}

	.feature-git-pill {
		height: 2.2rem;
		width: 5.5rem;
		overflow: hidden;
		align-items: flex-start;
		gap: 0.4rem;
		padding: 0 0.8rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(190, 148, 80, 0.26);
		background: rgba(250, 240, 221, 0.94);
		color: #8a6128;
		font-size: 0.75rem;
		font-weight: 600;
		white-space: nowrap;
		transition:
			width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
			background 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.35s ease;
	}

	.feature-git-pill__icon-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 2.2rem;
		flex-shrink: 0;
		transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.feature-git-pill__icon-wrap i {
		font-size: 0.9rem;
	}

	.feature-git-pill__text {
		display: flex;
		flex-direction: column;
		line-height: 1;
		align-self: flex-start;
		transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.feature-git-pill__text span {
		height: 2.2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
	}

	.feature-showcase__card:hover .feature-git-pill {
		width: 6.6rem;
		background: rgba(228, 240, 228, 0.98);
		border-color: rgba(102, 145, 103, 0.26);
		color: #406e4d;
		box-shadow: 0 10px 18px rgba(64, 110, 77, 0.11);
	}

	.feature-showcase__card:hover .feature-git-pill__icon-wrap {
		transform: rotate(180deg);
	}

	.feature-showcase__card:hover .feature-git-pill__text {
		transform: translateY(-2.2rem);
	}

	.feature-showcase__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		padding: 1.55rem 1.75rem;
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent) 88%, white 12%) 0%,
			color-mix(in srgb, var(--accent) 92%, black 8%) 100%
		);
		color: rgba(42, 28, 10, 0.95);
		position: relative;
		overflow: hidden;
	}

	.feature-showcase__footer::before {
		content: "";
		position: absolute;
		width: 12rem;
		height: 12rem;
		left: -2rem;
		top: -4rem;
		background: radial-gradient(circle, rgba(255, 241, 214, 0.32) 0%, transparent 68%);
	}

	.feature-showcase__footer-brand,
	.feature-showcase__footer-tags {
		position: relative;
		z-index: 1;
	}

	.feature-showcase__footer-brand {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.feature-showcase__footer-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 0.95rem;
		background: linear-gradient(
			180deg,
			color-mix(in srgb, var(--accent) 75%, white 25%),
			color-mix(in srgb, var(--accent) 88%, black 12%)
		);
		border: 1px solid color-mix(in srgb, var(--accent) 62%, black 38%);
		box-shadow: 0 10px 18px rgba(85, 44, 2, 0.18);
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.25s ease;
	}

	.feature-showcase__footer:hover .feature-showcase__footer-icon {
		transform: scale(1.05) rotate(9deg);
		border-color: rgba(128, 68, 6, 0.35);
	}

	.feature-showcase__footer-icon img {
		display: block;
		width: 1.45rem;
		height: 1.45rem;
		object-fit: contain;
	}

	.feature-showcase__footer h3 {
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin-bottom: 0.15rem;
	}

	.feature-showcase__footer p {
		font-size: 0.82rem;
		color: rgba(74, 46, 18, 0.78);
	}

	.feature-showcase__footer-tags {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
		font-size: 0.78rem;
		font-weight: 500;
		color: rgba(74, 46, 18, 0.82);
	}

	.feature-showcase__footer-tags span {
		display: inline-flex;
		align-items: center;
		line-height: 1;
	}

	.feature-showcase__footer-tags .is-struck {
		position: relative;
		opacity: 0.92;
	}

	.feature-showcase__footer-tags .is-struck::after {
		content: "";
		position: absolute;
		left: -5%;
		top: 60%;
		width: 110%;
		height: 1.5px;
		background: rgba(130, 32, 12, 0.78);
		border-radius: 999px;
		box-shadow: 0 0 8px rgba(130, 32, 12, 0.25);
		transform: translateY(-50%) rotate(-3deg);
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.feature-showcase__footer:hover .feature-showcase__footer-tags .is-struck::after {
		transform: translateY(-50%) rotate(-5deg) scale(1.04);
	}

	.feature-showcase__footer-tags .is-pill {
		padding: 0.38rem 0.72rem;
		border-radius: 0.7rem;
		background: rgba(255, 247, 235, 0.28);
		border: 1px solid rgba(99, 58, 16, 0.2);
	}

	.ft-coda {
		margin-top: 1.75rem;
		font-family: var(--sans);
		font-size: 0.8rem;
		color: var(--faint);
		letter-spacing: 0.01em;
		line-height: 1.6;
	}

	.ft-coda a {
		color: var(--muted);
		text-decoration: underline;
		text-underline-offset: 2px;
		text-decoration-color: rgba(17, 17, 17, 0.15);
		transition: color 0.15s ease, text-decoration-color 0.15s ease;
	}

	.ft-coda a:hover {
		color: var(--ink);
		text-decoration-color: var(--ink);
	}

	@media (max-width: 1080px) {
		.ft-section {
			width: 100%;
			margin-left: 0;
		}

		.feature-showcase__row--quad {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.feature-showcase__row--compact {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.feature-showcase__row--duo,
		.feature-showcase__row--quad,
		.feature-showcase__row--compact {
			grid-template-columns: 1fr;
		}

		.feature-showcase__card,
		.feature-showcase__card--hero,
		.feature-showcase__card--compact {
			min-height: auto;
		}

		.feature-showcase__footer {
			flex-direction: column;
			align-items: flex-start;
		}

		.feature-showcase__footer-tags {
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.feature-showcase__card,
		.feature-showcase__icon,
		.feature-showcase__card * {
			transition: none !important;
			animation: none !important;
		}

		.feature-showcase__card:hover {
			transform: none;
			box-shadow: none;
		}
	}

	/* ── FAQ ── */
	.faq-list {
		text-align: left;
		margin-top: 2rem;
		border: 1px solid var(--border);
	}

	.faq-item {
		border-bottom: 1px solid var(--border);
	}

	.faq-item:last-child { border-bottom: none; }

	.faq-summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.2rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
		transition: background 0.15s;
	}

	.faq-summary:hover { background: rgba(0,0,0,0.015); }
	.faq-summary::-webkit-details-marker { display: none; }
	.faq-summary::marker { display: none; content: ''; }

	.faq-q {
		font-size: 0.85rem;
		font-weight: 500;
		line-height: 1.55;
	}

	.faq-plus {
		font-size: 1rem;
		color: var(--faint);
		transition: transform 0.2s;
		flex-shrink: 0;
		margin-left: 1rem;
	}

	.faq-item[open] .faq-plus { transform: rotate(45deg); }

	.faq-a {
		padding: 0 1.2rem 1.2rem;
		font-size: 0.82rem;
		color: var(--muted);
		line-height: 1.7;
		overflow-wrap: anywhere;
	}

	/* ── CTA ── */
	.cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 5rem 0;
	}

	.cta .label,
	.cta h2 {
		width: 100%;
	}

	.cta-receipt {
		position: relative;
		align-self: center;
		width: min(31rem, calc(100vw - 2rem));
		max-width: 100%;
		margin: 1.8rem auto 0;
		margin-inline: auto;
		border: 1px solid rgba(213, 203, 188, 0.9);
		border-radius: 0.55rem;
		background: rgba(255, 253, 248, 0.98);
		overflow: hidden;
	}

	.cta-receipt__body {
		padding: 1.55rem 1.3rem 1.25rem;
	}

	.cta-receipt__perforation {
		height: 0.82rem;
		background:
			radial-gradient(circle at 0.42rem 50%, rgba(239, 235, 228, 0.98) 0.22rem, transparent 0.24rem)
			left center / 1.15rem 100% repeat-x;
	}

	.cta-receipt__brand {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding-bottom: 1rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__brand-lockup {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		text-align: center;
	}

	.cta-receipt__brand-copy {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.cta-receipt__brand-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.45rem;
		background: transparent;
		border: none;
		flex: none;
	}

	.cta-receipt__brand-icon img {
		width: 2.5rem;
		height: 2.5rem;
		display: block;
		border-radius: 0.35rem;
	}

	.cta-receipt__brand-name {
		font-family: var(--serif);
		font-size: 1.2rem;
		line-height: 0.95;
		letter-spacing: -0.03em;
		color: var(--ink);
	}

	.cta-receipt__brand-meta {
		margin-top: 0.24rem;
		font-size: 0.66rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(110, 96, 79, 0.72);
	}

	.cta-receipt__badge {
		display: none;
	}

	.cta-receipt__rows {
		display: grid;
		gap: 0.72rem;
		padding: 1rem 0 0.95rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.79rem;
		line-height: 1.4;
		color: rgba(94, 80, 63, 0.84);
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__row span:last-child {
		font-weight: 500;
		color: rgba(90, 77, 62, 0.76);
	}

	.cta-receipt__pricing {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.85rem;
		align-items: end;
		justify-content: center;
		padding: 1.1rem 0 1rem;
		border-bottom: 1px dashed rgba(189, 177, 160, 0.5);
	}

	.cta-receipt__pricing-copy {
		text-align: left;
	}

	.cta-receipt__pricing-label {
		font-size: 0.84rem;
		font-weight: 500;
		color: rgba(65, 55, 42, 0.9);
	}

	.cta-receipt__pricing-save {
		margin-top: 0.2rem;
		font-size: 0.7rem;
		color: #159647;
	}

	.cta-receipt__pricing-note {
		margin-top: 0.55rem;
		max-width: 11rem;
		font-size: 0.72rem;
		line-height: 1.55;
		color: rgba(112, 97, 79, 0.66);
	}

	.cta-receipt__pricing-amount {
		text-align: right;
	}

	.cta-receipt__special {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.48rem;
		border-radius: 0.22rem;
		background: var(--accent);
		color: rgba(255, 251, 244, 0.98);
		font-size: 0.58rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		transform: rotate(-6deg);
		transform-origin: center;
	}

	.cta-receipt__price-line {
		display: flex;
		align-items: flex-end;
		justify-content: flex-end;
		gap: 0.45rem;
		margin-top: 0.42rem;
	}

	.cta-receipt__price-old {
		font-size: 0.95rem;
		line-height: 1;
		color: rgba(130, 117, 101, 0.64);
		text-decoration: line-through;
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__price-new {
		font-family: var(--serif);
		font-size: clamp(2.25rem, 8vw, 3.35rem);
		line-height: 0.88;
		letter-spacing: -0.045em;
		color: var(--ink);
		font-variant-numeric: tabular-nums;
	}

	.cta-receipt__code {
		margin-top: 0.38rem;
		font-size: 0.7rem;
		color: rgba(93, 81, 69, 0.72);
	}

	.cta-receipt__code span {
		display: inline-flex;
		align-items: center;
		margin-left: 0.28rem;
		padding: 0.18rem 0.44rem;
		border-radius: 0.35rem;
		background: rgba(17, 17, 17, 0.06);
		border: 1px solid rgba(17, 17, 17, 0.08);
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--ink);
	}

	.cta-receipt__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 3.3rem;
		margin-top: 1.1rem;
		padding: 0.85rem 1.1rem;
		border-radius: 0.72rem;
		border: 1px solid rgba(39, 31, 22, 0.18);
		background: linear-gradient(180deg, #3b342d 0%, #27211c 100%);
		color: rgba(249, 244, 236, 0.98);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		box-shadow: 0 2px 12px rgba(39, 31, 22, 0.2), 0 1px 3px rgba(39, 31, 22, 0.1);
		transition:
			background 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease;
	}

	.cta-receipt__button:hover {
		background: #27211c;
		border-color: rgba(39, 31, 22, 0.26);
		box-shadow: 0 4px 16px rgba(39, 31, 22, 0.25), 0 1px 4px rgba(39, 31, 22, 0.12);
	}

	.cta-receipt__button:focus-visible {
		outline: 2px solid rgba(17, 17, 17, 0.15);
		outline-offset: 3px;
	}

	.cta-receipt__footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.4rem 1rem;
		padding-top: 0.95rem;
		margin-top: 0.9rem;
		border-top: 1px dashed rgba(189, 177, 160, 0.5);
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(160, 145, 126, 0.92);
	}

	.early-access-note {
		padding: 0.5rem 0 3.5rem;
		text-align: center;
	}

	.early-access-copy {
		max-width: 34rem;
		margin-inline: auto;
	}

	/* ── Footer ── */
	.footer {
		border-top: none;
		position: relative;
		left: 50%;
		width: 100vw;
		margin-left: -50vw;
		padding: 3rem 0 0;
	}

	.footer-shell {
		background: transparent;
		border: none;
		border-top: 1px solid rgba(149, 129, 102, 0.18);
		border-radius: 0;
		padding: 1.4rem clamp(1.5rem, 4vw, 2.75rem) 0;
		overflow: hidden;
		box-shadow: none;
	}

	.footer-columns {
		display: grid;
		grid-template-columns: 1.6fr repeat(3, 1fr);
		gap: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(149, 129, 102, 0.12);
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-col a:not(.footer-logo) {
		font-size: 0.82rem;
		color: rgba(69, 58, 43, 0.82);
		transition: color 0.15s;
	}

	.footer-col a:not(.footer-logo):hover {
		color: var(--ink);
	}

	.footer-heading {
		margin-bottom: 0.28rem;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		color: rgba(132, 112, 86, 0.72);
	}

	.footer-brand-col {
		gap: 0.45rem;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		width: fit-content;
	}

	.footer-tagline {
		font-size: 0.82rem;
		line-height: 1.5;
		color: rgba(96, 80, 60, 0.72);
	}

	.footer-meta {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.85rem;
		padding-top: 0.85rem;
		border-top: 1px solid rgba(149, 129, 102, 0.12);
	}

	.footer-copy {
		font-size: 0.76rem;
		color: rgba(69, 58, 43, 0.82);
		letter-spacing: 0.03em;
		white-space: nowrap;
	}

	.footer-credit {
		font-size: 0.74rem;
		color: rgba(132, 112, 86, 0.72);
		text-align: right;
	}

	.footer-showpiece {
		margin-top: 1rem;
		overflow: hidden;
	}

	.footer-trim {
		display: grid;
		grid-template-columns: repeat(30, minmax(0, 1fr));
		gap: 0.3rem;
		width: min(46rem, 100%);
		margin: 0 auto;
		position: relative;
		z-index: 2;
	}

	.footer-wordmark {
		display: block;
		width: 100%;
