---
import darkShowcaseAsset from "../../assets/dark.jpeg";
import lightShowcaseAsset from "../../assets/light.jpeg";
import logoG from "../../assets/logo_g.PNG";

import Layout from "../layouts/Layout.astro";
import { downloadUrl } from "../lib/site";

const showcaseSizes = "(max-width: 1200px) 96vw, 1100px";
const showcaseWidth = lightShowcaseAsset.width;
const showcaseHeight = lightShowcaseAsset.height;
const pageTitle = "Glyph: Local-First Markdown Notes App for macOS";
const pageDescription =
	"Learn how Glyph helps you capture ideas with markdown notes, wikilinks, tasks, and local-first AI on macOS. Private by default, fast, and built for deep work.";
const softwareUrl = Astro.site ? new URL("/", Astro.site).toString() : "/";
const softwareJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "Glyph",
		url: softwareUrl,
		description: pageDescription,
		potentialAction: {
			"@type": "SearchAction",
			target: Astro.site
				? `${new URL("/docs", Astro.site).toString()}?q={search_term_string}`
				: "/docs?q={search_term_string}",
			"query-input": "required name=search_term_string",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "Glyph",
		applicationCategory: "ProductivityApplication",
		operatingSystem: "macOS",
		description: pageDescription,
		url: softwareUrl,
		offers: {
			"@type": "Offer",
			price: "0",
			priceCurrency: "USD",
		},
	},
];

const features = [
	{
		num: "01",
		cat: "EDITOR",
		title: "Markdown-native.",
		desc: "A distraction-free editor with a floating toolbar, slash commands, and live preview. Every note is a plain .md file you own forever.",
	},
	{
		num: "02",
		cat: "CONNECTIONS",
		title: "Wikilinks & backlinks.",
		desc: "Connect any idea to any other with [[wikilinks]]. See what links back. Your notes stay linked together — no folders, no silos.",
	},
	{
		num: "03",
		cat: "INTELLIGENCE",
		title: "AI that knows you.",
		desc: "Ask questions about your own notes. Summarize, compare, or draft — powered by your existing ChatGPT subscription (Plus, Team, or Pro), Anthropic, or a local model you control.",
	},
	{
		num: "04",
		cat: "PRODUCTIVITY",
		title: "Tasks, tables & boards.",
		desc: "Drop a checkbox in any note. Organize with tables and kanban boards. Glyph pulls tasks into Inbox, Today, and Upcoming — no separate app needed.",
	},
	{
		num: "05",
		cat: "SEARCH",
		title: "Find anything, instantly.",
		desc: "Hit ⌘P and find anything — by tag, folder, or full-text. Results appear before you finish typing.",
	},
	{
		num: "06",
		cat: "CUSTOMIZATION",
		title: "Make it yours.",
		desc: "Accent colors, custom fonts, daily notes, and shortcuts — bend Glyph to match how you think.",
	},
];

const faqs = [
	{
		q: "Is there a subscription?",
		a: "No. Glyph is a one-time purchase with lifetime access. No recurring fees, no seat limits, no device binding.",
	},
	{
		q: "Do you collect my data?",
		a: "Never. Your notes stay on your Mac as plain markdown files. Nothing is uploaded, tracked, or phoned home. Ever.",
	},
	{
		q: "Can I try it before buying?",
		a: 'Yes. Glyph comes with a 7-day free trial. No credit card required — just <a href="https://github.com/SidhuK/Glyph/releases" target="_blank" rel="noopener" style="text-decoration:underline">download the latest version</a> and start writing.',
	},
	{
		q: "I can't afford it at the listed price. What should I do?",
		a: 'Please reach out on <a href="https://x.com/karat_sidhu" target="_blank" rel="noopener" style="text-decoration:underline">X</a> or email <a href="mailto:karatsidhu@gmail.com" style="text-decoration:underline">karatsidhu@gmail.com</a>. If you are a student or really strapped for cash, I will happily send you a discount code or a free license key.',
	},
	{
		q: "Is it open source?",
		a: "Yes. The source code is public on GitHub. Official release binaries are licensed, but you can always build from source.",
	},
	{
		q: "Is a Windows version planned?",
		a: "Eventually, yes. Glyph is built with cross-platform technology, so Windows and Linux are absolutely possible. Right now, all my energy goes into making the Mac experience exceptional.",
	},
];

const footerTrimMarks = Array.from({ length: 30 });
---

<Layout
	title={pageTitle}
	description={pageDescription}
	jsonLd={softwareJsonLd}
	preloadImage={lightShowcaseAsset.src}
	preloadImageSizes={showcaseSizes}
>
	<div class="page">

		<!-- ── HEADER ── -->
		<header class="header">
			<a href="/" class="logo">
				<img src={logoG.src} alt="" class="logo-icon" />
				<span>GLYPH</span>
				<span class="logo-version">EARLY ACCESS</span>
			</a>
			<nav class="nav">
				<a href="#features">Features</a>
				<a href="#pricing">Pricing</a>
				<a href="#faq">FAQs</a>
				<a href="/docs/introduction">Docs</a>
				<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
			</nav>
			<a href={downloadUrl} class="header-cta header-cta--desktop" target="_blank" rel="noopener">Download</a>
			<button class="header-hamburger" type="button" aria-label="Toggle menu" data-hamburger>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line class="hamburger-line hamburger-line--top" x1="4" y1="7" x2="20" y2="7"/><line class="hamburger-line hamburger-line--mid" x1="4" y1="12" x2="20" y2="12"/><line class="hamburger-line hamburger-line--bot" x1="4" y1="17" x2="20" y2="17"/></svg>
			</button>
		</header>
		<div class="mobile-nav" data-mobile-nav>
			<a href="#features">Features</a>
			<a href="#pricing">Pricing</a>
			<a href="#faq">FAQs</a>
			<a href="/docs/introduction">Docs</a>
			<a href="https://github.com/SidhuK/Glyph" target="_blank" rel="noopener">GitHub</a>
			<a href={downloadUrl} class="header-cta" target="_blank" rel="noopener">Download</a>
		</div>

		<!-- ── HERO ── -->
		<section class="hero">
			<h1>A quiet place for your<br />thoughts and ideas.<br /><span class="hero-accent">Always yours.</span></h1>
			<p class="hero-sub">Write in markdown. Connect ideas with links. Let AI help when you ask. Everything lives on your machine — plain files, always yours.</p>
			<p class="label">LOCAL-FIRST · MARKDOWN · MACOS</p>
			<div class="hero-cta-stack">
				<div class="hero-actions">
					<a href={downloadUrl} class="btn-primary" target="_blank" rel="noopener">
						<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516s1.52.087 2.475-1.258.762-2.391.728-2.43m3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422s1.675-2.789 1.698-2.854-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899s1.219.386 1.843.067c.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758q.52-1.185.473-1.282"/></svg>
						Download for Free
					</a>
				</div>
				<p class="hero-trial">Free 7-day trial · No credit card required</p>
				<div class="install-strip" aria-label="Homebrew install command" data-install-strip>
					<div class="install-strip-bar">
						<code class="install-strip-code" data-install-command>brew install --cask SidhuK/glyph/glyph</code>
						<button class="install-strip-copy" type="button" data-copy-install aria-label="Copy Homebrew install command" title="Copy command">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="9" y="9" width="10" height="10" rx="2"></rect>
								<path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
							</svg>
						</button>
					</div>
	
				</div>
				<p class="hero-pricing">or buy now · <span class="hero-pricing-original">$15</span> <strong>$9.99</strong> with code <code class="hero-pricing-code">EARLYACCESS</code></p>
			</div>
		</section>

		<!-- ── SHOWCASE ── -->
		<section class="showcase">
				<div class="showcase-wrap">
					<img
						class="showcase-img"
						src={lightShowcaseAsset.src}
						sizes={showcaseSizes}
						width={showcaseWidth}
						height={showcaseHeight}
						alt="Glyph in light mode"
						loading="eager"
						decoding="async"
						fetchpriority="high"
						data-light-src={lightShowcaseAsset.src}
						data-dark-src={darkShowcaseAsset.src}
						data-light-alt="Glyph in light mode"
						data-dark-alt="Glyph in dark mode"
					/>
			</div>
			<div class="mode-toggle-wrap">
				<button
					class="mode-toggle"
					type="button"
					data-mode-toggle
					aria-label="Switch between light and dark preview"
					aria-pressed="false"
				>
					<svg class="mode-icon icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
					<svg class="mode-icon icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				</button>
			</div>
		</section>

		<!-- ── FEATURES ── -->
		<section class="features-section" data-reveal id="features">
			<div class="feature-card-row feature-card-row--thirds">
				<div class="feature-card feature-card--compact feature-card--stacked bento-card-format">
					<div class="bento-card-content">
						<h3 class="feature-heading">Markdown-native. Write without friction.</h3>
						<p class="feature-body">A distraction-free editor with a floating toolbar, slash commands, and live preview. Every note is a plain .md file you own forever.</p>
					</div>
					<div class="bento-visual-wrapper">
						<svg class="svg-format" viewBox="0 0 100 100" aria-hidden="true">
							<rect class="doc-back" x="30" y="20" width="50" height="65" rx="4" fill="#d8e8dc" stroke="#a7c4ae" stroke-width="2"/>
							<rect class="doc-front" x="15" y="30" width="50" height="65" rx="4" fill="#f4f9f5" stroke="#a7c4ae" stroke-width="2"/>
							<path class="line line-1" d="M 25 50 H 55" stroke="#a7c4ae" stroke-width="3" stroke-linecap="round"/>
							<path class="line line-2" d="M 25 60 H 45" stroke="#a7c4ae" stroke-width="3" stroke-linecap="round"/>
							<path class="line line-3" d="M 25 70 H 50" stroke="#a7c4ae" stroke-width="3" stroke-linecap="round"/>
							<text class="md-mark" x="35" y="40" font-family="monospace" font-weight="bold" font-size="16" fill="#88a892">{}</text>
						</svg>
					</div>
				</div>
				<div class="feature-card feature-card--has-img feature-card--stacked">
					<div class="feature-card-text">
						<h3 class="feature-heading">Wikilinks & backlinks. Ideas stay connected.</h3>
						<p class="feature-body">Connect any idea to any other with [[wikilinks]]. See what links back. Your notes stay linked together — no folders, no silos.</p>
					</div>
					<div class="feature-card-img feature-card-img--wiki-svg">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="140 70 720 460" width="100%" height="100%" aria-hidden="true">
							<defs>
								<style>
									.wiki-text { font-family: -apple-system, BlinkMacSystemFont, "Geist", "Inter", "Segoe UI", Roboto, sans-serif; }
									.wiki-connection { stroke: #DCD7CA; stroke-width: 2.5; stroke-linecap: round; }
									.wiki-node-center-bg { fill: #242321; }
									.wiki-node-center-text { fill: #FFFFFF; font-size: 18px; font-weight: 500; text-anchor: middle; dominant-baseline: middle; }
									.wiki-node-peripheral { fill: #FFFFFF; stroke: #F0F0F0; stroke-width: 1.5; filter: drop-shadow(0px 2px 6px rgba(0,0,0,0.03)); }
									.wiki-node-text { fill: #403F3D; font-size: 16px; font-weight: 500; text-anchor: middle; dominant-baseline: middle; }

									.wiki-research-group { transform-origin: 700px 168px; animation: wikiScale 6s cubic-bezier(0.25, 1, 0.5, 1) infinite; cursor: pointer; }
									.wiki-popover-group { opacity: 0; animation: wikiFadePopover 6s cubic-bezier(0.25, 1, 0.5, 1) infinite; }
									.wiki-cursor { animation: wikiMoveCursor 6s cubic-bezier(0.25, 1, 0.5, 1) infinite; pointer-events: none; }

									@keyframes wikiScale {
										0%, 35% { transform: scale(1); }
										40%, 60% { transform: scale(1.04); }
										65%, 100% { transform: scale(1); }
									}
									@keyframes wikiFadePopover {
										0%, 35% { opacity: 0; transform: translateY(10px); }
										40%, 60% { opacity: 1; transform: translateY(0); }
										65%, 100% { opacity: 0; transform: translateY(10px); }
									}
									@keyframes wikiMoveCursor {
										0%, 15% { transform: translate(850px, 450px); }
										35%, 65% { transform: translate(690px, 172px); }
										85%, 100% { transform: translate(850px, 450px); }
									}

									.wiki-interactive:hover .wiki-cursor { opacity: 0; animation: none; }
									.wiki-interactive:hover .wiki-research-group { transform: scale(1.04); animation: none; }
									.wiki-interactive:hover .wiki-popover-group { opacity: 1; transform: translateY(0); animation: none; }
								</style>
							</defs>

							<!-- Connection Lines -->
							<line class="wiki-connection" x1="300" y1="168" x2="500" y2="300" />
							<line class="wiki-connection" x1="300" y1="432" x2="500" y2="300" />
							<line class="wiki-connection" x1="700" y1="432" x2="500" y2="300" />
							<line class="wiki-connection" x1="700" y1="168" x2="500" y2="300" />

							<!-- Daily Note -->
							<g>
								<rect class="wiki-node-peripheral" x="220" y="140" width="160" height="56" rx="12" />
								<text class="wiki-text wiki-node-text" x="300" y="168" dy="1">Daily Note</text>
							</g>

							<!-- Ideas -->
							<g>
								<rect class="wiki-node-peripheral" x="220" y="404" width="160" height="56" rx="12" />
								<text class="wiki-text wiki-node-text" x="300" y="432" dy="1">Ideas</text>
							</g>

							<!-- Backlinks -->
							<g>
								<rect class="wiki-node-peripheral" x="620" y="404" width="160" height="56" rx="12" />
								<text class="wiki-text wiki-node-text" x="700" y="432" dy="1">Backlinks</text>
							</g>

							<!-- Project Plan (Center) -->
							<g>
								<rect class="wiki-node-center-bg" x="400" y="265" width="200" height="70" rx="16" />
								<text class="wiki-text wiki-node-center-text" x="500" y="300" dy="1">Project Plan</text>
							</g>

							<!-- Interactive: Research + Popover + Cursor -->
							<g class="wiki-interactive">
								<g class="wiki-research-group">
									<rect class="wiki-node-peripheral" x="620" y="140" width="160" height="56" rx="12" style="filter: drop-shadow(0px 8px 16px rgba(0,0,0,0.06));" />
									<text class="wiki-text wiki-node-text" x="700" y="168" dy="1">Research</text>
								</g>
								<g class="wiki-popover-group">
									<rect fill="#1E1E1E" x="630" y="70" width="140" height="44" rx="10" />
									<polygon fill="#1E1E1E" points="692,113 708,113 700,121" />
									<text class="wiki-text" x="700" y="92" dy="1" fill="#FFFFFF" font-size="13" font-weight="600" text-anchor="middle" dominant-baseline="middle">2 new sources</text>
								</g>
								<g class="wiki-cursor">
									<path d="M 0 0 L 0 24 L 6 18 L 11 29 L 16 26 L 11 15 L 18 15 Z" fill="#1A1A1A" stroke="#FFFFFF" stroke-width="2" stroke-linejoin="round" />
								</g>
							</g>
						</svg>
					</div>
				</div>
				<div class="feature-card feature-card--has-img feature-card--stacked">
					<div class="feature-card-text">
						<h3 class="feature-heading">AI that knows your notes.</h3>
						<p class="feature-body">Ask questions about your own notes. Summarize, compare, or draft — powered by your existing ChatGPT subscription, Anthropic, or a local model.</p>
					</div>
					<div class="feature-card-img feature-card-img--ai-svg">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="-10 -10 720 520" width="100%" height="100%" aria-hidden="true">
							<defs>
								<filter id="ai-chat-shadow" x="-10%" y="-10%" width="120%" height="120%">
									<feDropShadow dx="0" dy="16" stdDeviation="32" flood-color="#000000" flood-opacity="0.06"/>
								</filter>
								<filter id="ai-user-shadow" x="-10%" y="-10%" width="120%" height="120%">
									<feDropShadow dx="0" dy="12" stdDeviation="24" flood-color="#000000" flood-opacity="0.12"/>
								</filter>
							</defs>
							<style>
								.ai-chat-text { font-family: -apple-system, BlinkMacSystemFont, "Geist", "Inter", "Segoe UI", Roboto, sans-serif; }

								@keyframes aiPopIn {
									0% { opacity: 0; transform: translateY(40px) scale(0.92); }
									70% { transform: translateY(-4px) scale(1.02); }
									100% { opacity: 1; transform: translateY(0) scale(1); }
								}
								@keyframes aiTypeLine {
									0% { clip-path: inset(0 100% 0 0); opacity: 0; }
									1% { opacity: 1; }
									100% { clip-path: inset(0 0 0 0); opacity: 1; }
								}
								@keyframes aiBounce {
									0%, 100% { transform: translateY(0); }
									50% { transform: translateY(-5px); }
								}
								@keyframes aiFadeOut {
									0% { opacity: 1; visibility: visible; }
									100% { opacity: 0; visibility: hidden; }
								}
								@keyframes aiSpin {
									100% { transform: rotate(360deg); }
								}

								.ai-hover-group { transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.4s ease; }
								.ai-user-bubble .ai-hover-group:hover { transform: translateY(-6px) scale(1.01); filter: drop-shadow(0 20px 32px rgba(0,0,0,0.15)); }
								.ai-response-bubble .ai-hover-group:hover { transform: translateY(-6px) scale(1.01); filter: drop-shadow(0 24px 40px rgba(0,0,0,0.08)); }
								.ai-response-bubble .ai-hover-group:hover .ai-claude-icon { animation: aiSpin 6s linear infinite; }

								.ai-user-bubble { opacity: 0; animation: aiPopIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.4s forwards; }
								.ai-response-bubble { opacity: 0; animation: aiPopIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1.1s forwards; }

								.ai-thinking-dots { animation: aiFadeOut 0.2s forwards 2.0s; }
								.ai-dot-1 { animation: aiBounce 0.6s infinite 1.1s; }
								.ai-dot-2 { animation: aiBounce 0.6s infinite 1.3s; }
								.ai-dot-3 { animation: aiBounce 0.6s infinite 1.5s; }

								.ai-type-line { clip-path: inset(0 100% 0 0); opacity: 0; }
								.ai-l1 { animation: aiTypeLine 0.6s steps(35, end) 2.1s forwards; }
								.ai-l2 { animation: aiTypeLine 0.6s steps(35, end) 2.7s forwards; }
								.ai-l3 { animation: aiTypeLine 0.6s steps(35, end) 3.3s forwards; }
								.ai-l4 { animation: aiTypeLine 0.7s steps(40, end) 3.9s forwards; }
								.ai-l5 { animation: aiTypeLine 0.6s steps(35, end) 4.6s forwards; }
								.ai-l6 { animation: aiTypeLine 0.6s steps(35, end) 5.2s forwards; }
								.ai-l7 { animation: aiTypeLine 0.4s steps(25, end) 5.8s forwards; }

								/* Hover replay */
								.feature-card--peach:hover .ai-user-bubble { animation-name: aiPopInH; animation-iteration-count: 1; }
								.feature-card--peach:hover .ai-response-bubble { animation-name: aiPopInH; animation-iteration-count: 1; }
								.feature-card--peach:hover .ai-thinking-dots { animation-name: aiFadeOutH; animation-iteration-count: 1; }
								.feature-card--peach:hover .ai-dot-1 { animation-name: aiBounceH; }
								.feature-card--peach:hover .ai-dot-2 { animation-name: aiBounceH; }
								.feature-card--peach:hover .ai-dot-3 { animation-name: aiBounceH; }
								.feature-card--peach:hover .ai-type-line.ai-l1 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l2 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l3 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l4 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l5 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l6 { animation-name: aiTypeLineH; }
								.feature-card--peach:hover .ai-type-line.ai-l7 { animation-name: aiTypeLineH; }

								@keyframes aiPopInH {
									0% { opacity: 0; transform: translateY(40px) scale(0.92); }
									70% { transform: translateY(-4px) scale(1.02); }
									100% { opacity: 1; transform: translateY(0) scale(1); }
								}
								@keyframes aiTypeLineH {
