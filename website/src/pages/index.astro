---
import { getImage } from "astro:assets";
import showcaseAsset from "../../assets/imageforWebsite.png";

import Layout from "../layouts/Layout.astro";

import EarlyAccess from "../sections/EarlyAccess.astro";
import FAQ from "../sections/FAQ.astro";
import Features from "../sections/Features.astro";
import Footer from "../sections/Footer.astro";
import Header from "../sections/Header.astro";
import Hero from "../sections/Hero.astro";
import Pricing from "../sections/Pricing.astro";
import Showcase from "../sections/Showcase.astro";

import "../styles/index.css";
import "../styles/features.css";
import "../styles/components.css";

const pageTitle = "Glyph: Local-First Markdown Notes App for macOS";
const pageDescription =
	"Learn how Glyph helps you capture ideas with markdown notes, wikilinks, tasks, and local-first AI on macOS. Private by default, fast, and built for deep work.";

const softwareUrl = Astro.site ? new URL("/", Astro.site).toString() : "/";
const softwareJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "Glyph",
		url: softwareUrl,
		description: pageDescription,
		potentialAction: {
			"@type": "SearchAction",
			target: "https://docs.glyphformac.com?q={search_term_string}",
			"query-input": "required name=search_term_string",
		},
	},
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "Glyph",
		applicationCategory: "ProductivityApplication",
		operatingSystem: "macOS",
		description: pageDescription,
		url: softwareUrl,
		offers: {
			"@type": "Offer",
			price: "0",
			priceCurrency: "USD",
		},
	},
];

// Build a responsive AVIF source set so the browser can preload the same
// image variants the <Picture> in Showcase.astro will render.
const showcaseWidths = [640, 960, 1200, 1600, showcaseAsset.width];
const preloadImages = await Promise.all(
	showcaseWidths.map((width) =>
		getImage({ src: showcaseAsset, format: "avif", width }),
	),
);
const preloadSrcSet = preloadImages
	.map((img, i) => `${img.src} ${showcaseWidths[i]}w`)
	.join(", ");
const preloadHref = preloadImages[preloadImages.length - 1].src;
---

<Layout
	title={pageTitle}
	description={pageDescription}
	jsonLd={softwareJsonLd}
	preloadImage={preloadHref}
	preloadImageSizes="(max-width: 1200px) 96vw, 1100px"
	preloadImageSrcSet={preloadSrcSet}
	preloadImageType="image/avif"
>
	<div class="page">
		<Header />
		<Hero />
		<Showcase />
		<Features />
		<Pricing />
		<FAQ />
		<EarlyAccess />
		<Footer />
	</div>
</Layout>

<script>
	import {
		initHamburger,
		initRevealAnimation,
		initClipboard,
		initRotateWords,
	} from "../lib/animations";

	initHamburger();
	initRevealAnimation();
	initClipboard();
	initRotateWords();
</script>
