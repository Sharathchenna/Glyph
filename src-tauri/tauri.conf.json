{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Glyph",
	"version": "0.8.0-alpha.5",
	"identifier": "com.karatsidhu.glyph",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Glyph",
				"width": 800,
				"height": 600,
				"minWidth": 680,
				"minHeight": 460,
				"decorations": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 14,
					"y": 22
				},
				"hiddenTitle": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": ["icons/icon.icns"],
		"fileAssociations": [
			{
				"ext": ["md", "markdown", "mdown"],
				"name": "Markdown Document",
				"description": "Markdown document",
				"role": "Editor",
				"mimeType": "text/markdown"
			}
		],
		"macOS": {
			"files": {
				"Resources/Assets.car": "./icons/Assets.car"
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzMDlDQjRBQkM2ODYzMEMKUldRTVkyaThTc3NKNHpsV1pzbXpnMFZPSXFKdnhWU082eFpjYU1nVlRWZjhuRVpQZXl5ekF6cGoK",
			"endpoints": [
				"https://raw.githubusercontent.com/SidhuK/Glyph/update-manifests/stable/latest.json"
			]
		}
	}
}
