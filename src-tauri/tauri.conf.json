{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Glyph",
	"version": "0.2.1",
	"identifier": "com.karatsidhu.glyph",
	"build": {
		"beforeDevCommand": "corepack pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "corepack pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Glyph",
				"width": 800,
				"height": 600,
				"decorations": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 14,
					"y": 20
				},
				"hiddenTitle": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": ["icons/icon.icns"],
		"macOS": {
			"files": {
				"Resources/Assets.car": "./icons/Assets.car"
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzMDlDQjRBQkM2ODYzMEMKUldRTVkyaThTc3NKNHpsV1pzbXpnMFZPSXFKdnhWU082eFpjYU1nVlRWZjhuRVpQZXl5ekF6cGoK",
			"endpoints": [
				"https://github.com/SidhuK/Glyph/releases/latest/download/latest.json"
			]
		}
	}
}
