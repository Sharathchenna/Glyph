{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Glyph",
	"version": "0.8.8-alpha.2",
	"identifier": "com.sharathchenna.glyph",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"create": false,
				"visible": false,
				"title": "Glyph",
				"width": 800,
				"height": 600,
				"minWidth": 680,
				"minHeight": 460,
				"decorations": true,
				"titleBarStyle": "Overlay",
				"trafficLightPosition": {
					"x": 12,
					"y": 28
				},
				"hiddenTitle": true,
				"transparent": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"fileAssociations": [
			{
				"ext": ["md", "markdown", "mdown"],
				"name": "Markdown Document",
				"description": "Markdown document",
				"role": "Editor",
				"mimeType": "text/markdown"
			}
		],
		"macOS": {
			"dmg": {
				"background": "./icons/dmg-background.png"
			},
			"files": {
				"Resources/Assets.car": "./icons/Assets.car"
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMTg4QUU2NkVDOUEyMjAKUldRZ29zbHU1b29ZU2hKT2JGcnpoTmxWRkZISnFvUC8vMDZheURYMlgwa3dGd29BMjd1S294emsK",
			"endpoints": [
				"https://raw.githubusercontent.com/Sharathchenna/Glyph/update-manifests/stable/latest.json"
			],
			"windows": {
				"installMode": "passive"
			}
		}
	}
}
